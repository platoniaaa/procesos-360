---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import Team from '../components/Team.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Nosotros | Procesos 360 — Consultoría en Gestión por Procesos"
  description="Consultora chilena especializada en gestión por procesos, transformación digital con IA y modelamiento empresarial. Conoce nuestra visión, misión, enfoque y al equipo detrás de Procesos 360."
>
  <!-- Hero ¿Quiénes somos? -->
  <section class="nosotros-hero">
    <div class="nosotros-hero-inner">
      <div class="nosotros-hero-left">
        <div class="eyebrow eyebrow-dot mb-5">Nosotros</div>
        <h1 class="nosotros-hero-title">
          &iquest;Qui&eacute;nes<br/>somos?
        </h1>
      </div>
      <div class="nosotros-hero-right">
        <p class="nosotros-hero-lead">
          Transformando tus procesos en tus <span class="italic-accent">activos estrat&eacute;gicos</span>
        </p>
        <p class="nosotros-hero-text">
          Estamos comprometidos con la excelencia en la gesti&oacute;n de procesos para impulsar el &eacute;xito empresarial. Con una trayectoria probada en el dise&ntilde;o, implementaci&oacute;n y optimizaci&oacute;n, nos hemos consolidado como l&iacute;deres en el campo de la consultor&iacute;a de la Gesti&oacute;n de procesos de negocios.
        </p>
        <a href="/#contacto" class="nosotros-hero-cta">Conversemos</a>
      </div>
    </div>
  </section>

  <About />
  <Team />
  <ContactForm />

  <Footer />
</Layout>

<style>
  .nosotros-hero {
    position: relative;
    background: var(--night);
    padding: 8rem 1.5rem 4rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .nosotros-hero { padding: 11rem 4rem 6rem; }
  }

  .nosotros-hero-inner {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: end;
  }
  @media (min-width: 900px) {
    .nosotros-hero-inner {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 4rem;
    }
  }

  .nosotros-hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3.5rem, 11vw, 9rem);
    line-height: 0.92;
    letter-spacing: -0.045em;
    color: var(--cream);
    margin: 0;
  }

  .nosotros-hero-right {
    padding-bottom: 0.5rem;
  }
  .nosotros-hero-lead {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--cream);
    margin: 0 0 1.25rem;
  }
  .nosotros-hero-text {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 2rem;
  }
  .nosotros-hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: #FFFFFF;
    background: var(--plum);
    padding: 0.9rem 2.25rem;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
  }
  .nosotros-hero-cta:hover {
    transform: translateY(-2px);
    background: var(--violet);
  }
</style>
