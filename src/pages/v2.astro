---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Procesos 360 — Diseño alternativo (V2)</title>
    <meta name="description" content="Versión alternativa del sitio de Procesos 360." />
    <link rel="icon" type="image/png" href="/img/isotipo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      :root {
        --v2-bg: #ffffff;
        --v2-bg-soft: #f4f6f9;
        --v2-text: #1f2937;
        --v2-text-soft: #4b5563;
        --v2-text-muted: #6b7280;
        --v2-primary: #1e3a8a;
        --v2-primary-deep: #172554;
        --v2-primary-soft: #3b5bdb;
        --v2-accent: #f59e0b;
        --v2-border: #e5e7eb;
        --v2-shadow: 0 1px 3px rgba(0,0,0,0.06), 0 8px 24px rgba(15,23,42,0.05);
        --v2-shadow-lg: 0 12px 32px rgba(30,58,138,0.10);
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        color: var(--v2-text);
        background: var(--v2-bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        line-height: 1.6;
      }
      img { max-width: 100%; display: block; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3, h4 { margin: 0; line-height: 1.2; letter-spacing: -0.02em; font-weight: 700; }
      p { margin: 0; }

      .v2-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

      /* ---------- NAVBAR ---------- */
      .v2-navbar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--v2-border);
      }
      .v2-nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
      }
      .v2-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        font-size: 18px;
        color: var(--v2-primary);
        letter-spacing: -0.02em;
      }
      .v2-logo img { height: 28px; width: auto; }
      .v2-nav-links {
        display: none;
        gap: 32px;
        font-size: 14px;
        font-weight: 500;
        color: var(--v2-text-soft);
      }
      @media (min-width: 900px) {
        .v2-nav-links { display: flex; }
      }
      .v2-nav-links a:hover { color: var(--v2-primary); }
      .v2-nav-cta {
        background: var(--v2-primary);
        color: white;
        padding: 10px 22px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 14px;
        transition: background 0.2s;
      }
      .v2-nav-cta:hover { background: var(--v2-primary-deep); }

      /* ---------- HERO SLIDER (estilo MSO) ---------- */
      .v2-hero {
        background: linear-gradient(135deg, #0a1f4a 0%, #1e3a8a 60%, #2748b8 100%);
        color: white;
        position: relative;
        overflow: hidden;
        min-height: 540px;
      }
      .v2-hero::before {
        content: '';
        position: absolute;
        top: -150px;
        right: -150px;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 65%);
        pointer-events: none;
      }
      .v2-slider {
        position: relative;
        padding: 80px 0 100px;
      }
      .v2-slide {
        display: none;
        align-items: center;
        gap: 48px;
        animation: v2-fade 0.6s ease;
      }
      .v2-slide.is-active { display: grid; grid-template-columns: 1fr; }
      @media (min-width: 900px) {
        .v2-slide.is-active { grid-template-columns: 1.05fr 0.95fr; gap: 56px; }
      }
      @keyframes v2-fade {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .v2-slide-eyebrow {
        display: inline-block;
        font-size: 14px;
        font-weight: 500;
        color: rgba(255,255,255,0.85);
        margin-bottom: 14px;
      }
      .v2-slide h1 {
        font-size: clamp(32px, 4.5vw, 50px);
        font-weight: 800;
        color: white;
        margin-bottom: 20px;
        line-height: 1.15;
      }
      .v2-slide-sub {
        font-size: 16px;
        line-height: 1.65;
        color: rgba(255,255,255,0.8);
        margin-bottom: 28px;
        max-width: 520px;
      }
      .v2-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 32px;
        font-weight: 600;
        font-size: 15px;
        border-radius: 999px;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
        text-decoration: none;
      }
      .v2-btn-orange {
        background: #f59e0b;
        color: #0a1f4a;
      }
      .v2-btn-orange:hover { background: #fbbf24; transform: translateY(-1px); }
      .v2-btn-primary {
        background: var(--v2-primary);
        color: white;
        border-radius: 6px;
      }
      .v2-btn-primary:hover {
        background: var(--v2-primary-deep);
        transform: translateY(-1px);
        box-shadow: var(--v2-shadow-lg);
      }
      .v2-btn-ghost {
        background: transparent;
        color: var(--v2-primary);
        border: 1.5px solid var(--v2-primary);
        border-radius: 6px;
      }
      .v2-btn-ghost:hover { background: var(--v2-primary); color: white; }

      /* Blob con imagen/gradiente al estilo MSO */
      .v2-blob-wrap {
        position: relative;
        aspect-ratio: 1/1;
        max-width: 480px;
        margin: 0 auto;
      }
      .v2-blob {
        position: absolute;
        inset: 0;
        border-radius: 62% 38% 46% 54% / 58% 42% 58% 42%;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: v2-blob-morph 14s ease-in-out infinite;
      }
      @keyframes v2-blob-morph {
        0%, 100% { border-radius: 62% 38% 46% 54% / 58% 42% 58% 42%; }
        33% { border-radius: 42% 58% 60% 40% / 48% 62% 38% 52%; }
        66% { border-radius: 54% 46% 36% 64% / 60% 50% 50% 40%; }
      }
      .v2-blob-icon {
        width: 50%;
        height: 50%;
        color: white;
        opacity: 0.95;
      }
      .v2-blob-ring {
        position: absolute;
        inset: -16px;
        border: 1.5px solid rgba(255,255,255,0.25);
        border-radius: 50%;
        animation: v2-spin 24s linear infinite;
      }
      @keyframes v2-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .v2-blob-deco {
        position: absolute;
        background: #fbbf24;
        border-radius: 999px;
        opacity: 0.85;
      }
      .v2-blob-deco-1 { width: 80px; height: 28px; bottom: 10%; left: -10px; transform: rotate(-15deg); }

      /* Decorativos zigzag */
      .v2-deco-zigzag {
        position: absolute;
        opacity: 0.6;
        pointer-events: none;
      }
      .v2-deco-zigzag-left { bottom: 40px; left: 24px; width: 120px; color: #f59e0b; }
      .v2-deco-zigzag-right { bottom: 30px; right: 24px; width: 120px; color: #f59e0b; }

      /* Dots indicators */
      .v2-dots {
        position: absolute;
        bottom: 36px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 10px;
        z-index: 5;
      }
      .v2-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        border: none;
        cursor: pointer;
        padding: 0;
        transition: all 0.3s;
      }
      .v2-dot.is-active { background: white; transform: scale(1.2); }
      .v2-dot:hover { background: rgba(255,255,255,0.6); }

      /* ---------- METRICS ---------- */
      .v2-metrics {
        background: var(--v2-bg);
        padding: 56px 0;
        border-bottom: 1px solid var(--v2-border);
      }
      .v2-metrics-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 32px;
      }
      @media (min-width: 768px) {
        .v2-metrics-grid { grid-template-columns: repeat(4, 1fr); }
      }
      .v2-metric { text-align: center; }
      .v2-metric-num {
        font-size: clamp(36px, 5vw, 52px);
        font-weight: 800;
        color: var(--v2-primary);
        margin-bottom: 6px;
        line-height: 1;
      }
      .v2-metric-label {
        font-size: 13px;
        font-weight: 500;
        color: var(--v2-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      /* ---------- SECTION BASE ---------- */
      .v2-section { padding: 96px 0; }
      .v2-section-soft { background: var(--v2-bg-soft); }
      .v2-section-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
      .v2-section-eyebrow {
        font-size: 13px;
        font-weight: 600;
        color: var(--v2-primary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 12px;
      }
      .v2-section-title {
        font-size: clamp(28px, 4vw, 40px);
        font-weight: 700;
        color: var(--v2-text);
        margin-bottom: 14px;
      }
      .v2-section-sub {
        font-size: 16px;
        color: var(--v2-text-soft);
        line-height: 1.65;
      }

      /* ---------- ABOUT ---------- */
      .v2-about-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 48px;
        align-items: center;
      }
      @media (min-width: 900px) {
        .v2-about-grid { grid-template-columns: 1fr 1fr; gap: 64px; }
      }
      .v2-about-text h2 { font-size: clamp(28px, 3.5vw, 38px); margin-bottom: 20px; }
      .v2-about-text p { color: var(--v2-text-soft); font-size: 16px; line-height: 1.7; margin-bottom: 16px; }
      .v2-about-image {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--v2-shadow);
        aspect-ratio: 4/3;
        background: linear-gradient(135deg, var(--v2-primary) 0%, var(--v2-primary-soft) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
      }
      .v2-about-image-inner {
        padding: 40px;
        text-align: center;
      }
      .v2-about-image-inner .num { font-size: 96px; font-weight: 800; line-height: 1; margin-bottom: 8px; }
      .v2-about-image-inner .lbl { font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.9; }

      /* ---------- SERVICIOS ---------- */
      .v2-services-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
      }
      @media (min-width: 640px) { .v2-services-grid { grid-template-columns: repeat(2, 1fr); } }
      @media (min-width: 1024px) { .v2-services-grid { grid-template-columns: repeat(3, 1fr); } }
      .v2-service-card {
        background: white;
        border: 1px solid var(--v2-border);
        border-radius: 12px;
        padding: 28px;
        transition: all 0.25s ease;
      }
      .v2-service-card:hover {
        border-color: var(--v2-primary);
        transform: translateY(-3px);
        box-shadow: var(--v2-shadow-lg);
      }
      .v2-service-icon {
        width: 44px;
        height: 44px;
        background: rgba(30,58,138,0.08);
        color: var(--v2-primary);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 18px;
        margin-bottom: 18px;
      }
      .v2-service-card h3 { font-size: 18px; margin-bottom: 10px; color: var(--v2-text); }
      .v2-service-card p { font-size: 14px; line-height: 1.6; color: var(--v2-text-soft); }

      /* ---------- CASOS ---------- */
      .v2-casos-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
      }
      @media (min-width: 768px) { .v2-casos-grid { grid-template-columns: repeat(2, 1fr); } }
      .v2-caso-card {
        background: white;
        border: 1px solid var(--v2-border);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--v2-shadow);
        transition: transform 0.25s, box-shadow 0.25s;
      }
      .v2-caso-card:hover { transform: translateY(-4px); box-shadow: var(--v2-shadow-lg); }
      .v2-caso-image {
        height: 160px;
        background: linear-gradient(135deg, #eef2ff 0%, #dbeafe 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .v2-caso-image img { max-height: 80px; max-width: 200px; object-fit: contain; }
      .v2-caso-body { padding: 28px; }
      .v2-caso-cliente {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--v2-primary);
        margin-bottom: 8px;
      }
      .v2-caso-card h3 { font-size: 19px; margin-bottom: 12px; }
      .v2-caso-card p { font-size: 14px; line-height: 1.6; color: var(--v2-text-soft); }

      /* ---------- EQUIPO ---------- */
      .v2-team-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
      }
      @media (min-width: 768px) { .v2-team-grid { grid-template-columns: repeat(3, 1fr); } }
      .v2-team-member { text-align: center; }
      .v2-team-photo {
        width: 180px;
        height: 180px;
        margin: 0 auto 20px;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid white;
        box-shadow: var(--v2-shadow);
      }
      .v2-team-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 20%; }
      .v2-team-member h4 { font-size: 17px; margin-bottom: 4px; }
      .v2-team-member .rol { font-size: 13px; color: var(--v2-primary); font-weight: 500; }

      /* ---------- CLIENTES ---------- */
      .v2-clients-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--v2-border);
        border: 1px solid var(--v2-border);
        border-radius: 8px;
        overflow: hidden;
      }
      @media (min-width: 640px) { .v2-clients-grid { grid-template-columns: repeat(4, 1fr); } }
      @media (min-width: 900px) { .v2-clients-grid { grid-template-columns: repeat(5, 1fr); } }
      .v2-client-cell {
        background: white;
        aspect-ratio: 4/3;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        transition: background 0.2s;
      }
      .v2-client-cell:hover { background: var(--v2-bg-soft); }
      .v2-client-cell img { max-width: 80%; max-height: 60%; object-fit: contain; filter: grayscale(1); opacity: 0.7; transition: all 0.25s; }
      .v2-client-cell:hover img { filter: grayscale(0); opacity: 1; }

      /* ---------- NEWSLETTER / CONTACTO ---------- */
      .v2-contact {
        background: var(--v2-primary);
        color: white;
        padding: 80px 0;
      }
      .v2-contact-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
        align-items: center;
      }
      @media (min-width: 900px) { .v2-contact-grid { grid-template-columns: 1fr 1fr; gap: 64px; } }
      .v2-contact h2 { color: white; font-size: clamp(28px, 3.5vw, 38px); margin-bottom: 16px; }
      .v2-contact p { color: rgba(255,255,255,0.85); font-size: 16px; line-height: 1.65; }
      .v2-form { display: grid; gap: 12px; }
      .v2-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      .v2-form input, .v2-form textarea, .v2-form select {
        padding: 14px 16px;
        border-radius: 6px;
        border: none;
        font-family: inherit;
        font-size: 15px;
        background: white;
        color: var(--v2-text);
      }
      .v2-form textarea { min-height: 110px; resize: vertical; }
      .v2-form button {
        background: var(--v2-accent);
        color: var(--v2-primary-deep);
        padding: 14px 28px;
        border: none;
        border-radius: 6px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 6px;
      }
      .v2-form button:hover { background: #fbbf24; }

      /* ---------- FOOTER ---------- */
      .v2-footer {
        background: #0f172a;
        color: #cbd5e1;
        padding: 56px 0 24px;
        font-size: 14px;
      }
      .v2-footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
        margin-bottom: 40px;
      }
      @media (min-width: 768px) { .v2-footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; } }
      .v2-footer h5 { color: white; font-size: 14px; margin-bottom: 14px; letter-spacing: 0.04em; text-transform: uppercase; }
      .v2-footer ul { list-style: none; padding: 0; margin: 0; }
      .v2-footer li { margin-bottom: 8px; }
      .v2-footer a:hover { color: white; }
      .v2-footer-brand p { color: #94a3b8; line-height: 1.6; margin-top: 12px; }
      .v2-footer-bottom {
        padding-top: 24px;
        border-top: 1px solid #1e293b;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        font-size: 13px;
        color: #64748b;
      }
    </style>
  </head>

  <body>

    <!-- ============ NAVBAR ============ -->
    <header class="v2-navbar">
      <div class="v2-container v2-nav-inner">
        <a href="/v2" class="v2-logo">
          <img src="/img/isotipo.png" alt="Procesos 360" />
          <span>PROCESOS 360</span>
        </a>
        <nav class="v2-nav-links">
          <a href="#nosotros">Nosotros</a>
          <a href="#servicios">Servicios</a>
          <a href="#productos">Productos</a>
          <a href="#casos">Casos</a>
          <a href="#contacto">Contacto</a>
        </nav>
        <a href="#contacto" class="v2-nav-cta">Contáctanos</a>
