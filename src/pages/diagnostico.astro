---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import pemmData from '../data/pemm.json';

const empresaData = pemmData.empresa;
const procesoData = pemmData.proceso;
---

<Layout
  title="Diagnóstico de Madurez de Procesos | Procesos 360"
  description="Evaluación gratuita basada en el modelo PEMM de Michael Hammer. Recibe un diagnóstico personalizado generado por IA con recomendaciones accionables en menos de 5 minutos."
>
  <Navbar />

  <main class="diag-main">
    <div class="diag-container">

      <!-- ===== STEP: INTRO ===== -->
      <section id="step-intro" class="diag-step active">
        <div class="diag-eyebrow eyebrow eyebrow-dot">Diagnóstico gratuito</div>
        <h1 class="display-lg mt-4 mb-6">
          ¿Qué tan madura es la <span class="italic-accent">gestión de procesos</span> de tu empresa?
        </h1>
        <p class="text-lg leading-relaxed max-w-2xl mb-10" style="color:var(--text-muted);">
          Una evaluación basada en <strong style="color:var(--cream);">PEMM</strong>, el modelo de
          Michael Hammer (Harvard Business Review). Te entregamos un diagnóstico personalizado
          generado por inteligencia artificial con recomendaciones accionables. Cinco a treinta
          minutos según el nivel de detalle que elijas.
        </p>

        <div class="diag-features">
          <div class="diag-feat">
            <div class="diag-feat-num">01</div>
            <div>
              <h3>Evaluación estructurada</h3>
              <p>Un cuestionario riguroso por categoría: liderazgo, cultura, experticia, gobernabilidad y, opcionalmente, un proceso específico.</p>
            </div>
          </div>
          <div class="diag-feat">
            <div class="diag-feat-num">02</div>
            <div>
              <h3>Diagnóstico con IA</h3>
              <p>Tus resultados se analizan junto con el marco PEMM para generar un informe con tus fortalezas, prioridades y un plan a 90 días.</p>
            </div>
          </div>
          <div class="diag-feat">
            <div class="diag-feat-num">03</div>
            <div>
              <h3>Reporte por email</h3>
              <p>Recibes el informe completo en tu correo para compartirlo con tu equipo. Sin compromiso, sin venta dura.</p>
            </div>
          </div>
        </div>

        <button class="btn-primary mt-10 diag-btn-next" data-next="step-lead">
          Empezar diagnóstico
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </section>

      <!-- ===== STEP: LEAD CAPTURE ===== -->
      <section id="step-lead" class="diag-step">
        <div class="diag-progress"><div class="diag-progress-bar" style="width:10%;"></div></div>
        <div class="diag-eyebrow eyebrow">Paso 1 de 4</div>
        <h2 class="display-md mt-4 mb-3">¿Dónde te enviamos el reporte?</h2>
        <p class="diag-sub mb-8">Tu reporte completo llegará a este correo. Solo lo usamos para contactarte si nos das la autorización; nada de spam.</p>

        <form id="lead-form" class="diag-form">
          <div class="diag-row">
            <label>Nombre *</label>
            <input type="text" name="nombre" required placeholder="Ej: María González" autocomplete="name" />
          </div>
          <div class="diag-row">
            <label>Email *</label>
            <input type="email" name="email" required placeholder="tu@email.com" autocomplete="email" />
          </div>
          <div class="diag-row">
            <label>Empresa *</label>
            <input type="text" name="empresa" required placeholder="Ej: Panadería Don José" autocomplete="organization" />
          </div>
          <div class="diag-row">
            <label>Cargo</label>
            <input type="text" name="cargo" placeholder="Ej: Gerente de Operaciones" />
          </div>
          <div class="diag-row">
            <label>WhatsApp (opcional)</label>
            <input type="tel" name="telefono" placeholder="+56 9 XXXX XXXX" autocomplete="tel" />
          </div>

          <div class="diag-actions">
            <button type="button" class="btn-secondary diag-btn-back" data-back="step-intro">← Volver</button>
            <button type="submit" class="btn-primary">Continuar →</button>
          </div>
        </form>
      </section>

      <!-- ===== STEP: TYPE SELECT ===== -->
      <section id="step-type" class="diag-step">
        <div class="diag-progress"><div class="diag-progress-bar" style="width:30%;"></div></div>
        <div class="diag-eyebrow eyebrow">Paso 2 de 4</div>
        <h2 class="display-md mt-4 mb-3">¿Qué quieres diagnosticar?</h2>
        <p class="diag-sub mb-8">Puedes evaluar la organización completa, un proceso específico, o ambos.</p>

        <div class="diag-cards">
          <button type="button" class="diag-card" data-type="empresa">
            <div class="diag-card-num">A</div>
            <h3>Empresa</h3>
            <p>13 dimensiones organizacionales. Mide qué tan preparada está tu organización para gestionar por procesos.</p>
            <div class="diag-card-meta">Liderazgo · Cultura · Experticia · Gobernabilidad</div>
          </button>
          <button type="button" class="diag-card" data-type="proceso">
            <div class="diag-card-num">B</div>
            <h3>Proceso específico</h3>
            <p>13 dimensiones de un proceso concreto (ej: ventas, postventa, facturación). Mide la madurez de ESE proceso.</p>
            <div class="diag-card-meta">Diseño · Ejecutores · Dueño · Infraestructura · Indicadores</div>
          </button>
          <button type="button" class="diag-card diag-card-featured" data-type="ambos">
            <div class="diag-card-num">A+B</div>
            <h3>Ambos <span class="diag-badge">Recomendado</span></h3>
            <p>Evalúa empresa + un proceso. Verás cómo se relacionan y dónde está el cuello de botella.</p>
            <div class="diag-card-meta">26 dimensiones en total</div>
          </button>
        </div>

        <div class="diag-actions mt-10">
          <button type="button" class="btn-secondary diag-btn-back" data-back="step-lead">← Volver</button>
        </div>
      </section>

      <!-- ===== STEP: MODE SELECT ===== -->
      <section id="step-mode" class="diag-step">
        <div class="diag-progress"><div class="diag-progress-bar" style="width:50%;"></div></div>
        <div class="diag-eyebrow eyebrow">Paso 3 de 4</div>
        <h2 class="display-md mt-4 mb-3">¿Express o completo?</h2>
        <p class="diag-sub mb-8">El express te da un nivel orientativo en pocos minutos. El completo es la versión fiel al PEMM original con escala Verde/Amarillo/Rojo por afirmación.</p>

        <div class="diag-cards">
          <button type="button" class="diag-card" data-mode="express">
            <div class="diag-card-num">⚡</div>
            <h3>Express</h3>
            <p>Una pregunta por dimensión. Eliges el nivel que mejor describe tu realidad.</p>
            <div class="diag-card-meta" id="mode-express-time">~5 minutos · 13 preguntas</div>
          </button>
          <button type="button" class="diag-card" data-mode="completo">
            <div class="diag-card-num">📋</div>
            <h3>Completo</h3>
            <p>Cuatro afirmaciones por dimensión, calificadas Verde/Amarillo/Rojo. Más preciso para tu reporte.</p>
            <div class="diag-card-meta" id="mode-completo-time">~25-30 minutos · 52 preguntas</div>
          </button>
        </div>

        <div class="diag-actions mt-10">
          <button type="button" class="btn-secondary diag-btn-back" data-back="step-type">← Volver</button>
        </div>
      </section>

      <!-- ===== STEP: PROCESS NAME (only for tipo proceso/ambos) ===== -->
      <section id="step-proceso-name" class="diag-step">
        <div class="diag-progress"><div class="diag-progress-bar" style="width:55%;"></div></div>
        <div class="diag-eyebrow eyebrow">Paso opcional</div>
        <h2 class="display-md mt-4 mb-3">¿Qué proceso quieres evaluar?</h2>
        <p class="diag-sub mb-8">Especifica el proceso para que el diagnóstico sea más preciso. Por ejemplo: "Atención al cliente", "Facturación", "Reclutamiento".</p>

        <form id="proceso-name-form" class="diag-form" style="max-width:500px;">
          <div class="diag-row">
            <label>Nombre del proceso *</label>
            <input type="text" name="procesoNombre" required placeholder="Ej: Atención al cliente" />
          </div>
          <div class="diag-actions">
            <button type="button" class="btn-secondary diag-btn-back" data-back="step-mode">← Volver</button>
            <button type="submit" class="btn-primary">Continuar →</button>
          </div>
        </form>
      </section>

      <!-- ===== STEP: QUESTIONS ===== -->
      <section id="step-questions" class="diag-step">
        <div class="diag-progress"><div id="questions-progress" class="diag-progress-bar" style="width:60%;"></div></div>
        <div class="diag-eyebrow eyebrow"><span id="questions-section-label">Sección 1 de 4</span></div>
        <h2 class="display-md mt-4 mb-2" id="questions-title">Liderazgo</h2>
        <p class="diag-sub mb-8" id="questions-sub">Para cada dimensión, marca la opción que mejor describe la realidad de tu empresa.</p>

        <div id="questions-list"></div>

        <div class="diag-actions diag-actions-questions mt-10">
          <button type="button" class="btn-secondary" id="questions-prev">← Anterior</button>
          <button type="button" class="btn-primary" id="questions-next">Siguiente →</button>
        </div>
      </section>

      <!-- ===== STEP: LOADING ===== -->
      <section id="step-loading" class="diag-step">
        <div class="diag-loading">
          <div class="diag-loading-spinner"></div>
          <h2 class="display-md mt-8 mb-3">Procesando tu diagnóstico…</h2>
          <p class="diag-sub" id="loading-status">Calculando niveles de madurez por dimensión.</p>
          <div class="diag-loading-steps">
            <div class="diag-loading-step active" data-step="calc">Calculando scores</div>
            <div class="diag-loading-step" data-step="ai">Generando análisis con IA</div>
            <div class="diag-loading-step" data-step="email">Enviando reporte por email</div>
          </div>
        </div>
      </section>

      <!-- ===== STEP: RESULT ===== -->
      <section id="step-result" class="diag-step">
        <div class="diag-eyebrow eyebrow eyebrow-dot" style="color:var(--gold);">Tu diagnóstico</div>
        <h2 class="display-lg mt-4 mb-3">
          Resultado de <span class="italic-accent" id="result-name-display">tu empresa</span>
        </h2>
        <p class="diag-sub mb-10" id="result-sub">Un análisis personalizado generado a partir de tus respuestas y el marco PEMM.</p>

        <!-- Score cards -->
        <div id="result-scorecards" class="diag-scorecards"></div>

        <!-- Detailed breakdown -->
        <div id="result-breakdown" class="diag-breakdown mt-10"></div>

        <!-- AI-generated diagnostic -->
        <div id="result-ai" class="diag-ai mt-12"></div>

        <!-- CTA -->
        <div class="diag-cta mt-12">
          <h3 class="display-md mb-4">¿Quieres ayuda para implementarlo?</h3>
          <p class="text-base mb-6" style="color:var(--text-muted);max-width:540px;">
            Una llamada de 30 minutos sin compromiso. Te ayudamos a priorizar y construir un plan
            con tu equipo.
          </p>
          <div class="flex gap-3 flex-wrap">
            <a href="https://wa.me/56964261751?text=Hola,%20completé%20el%20diagnóstico%20PEMM%20y%20me%20gustaría%20agendar%20una%20llamada" target="_blank" rel="noopener noreferrer" class="btn-primary">
              Agendar llamada
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/" class="btn-secondary">Volver al inicio</a>
          </div>
        </div>
      </section>

      <!-- ===== STEP: ERROR ===== -->
      <section id="step-error" class="diag-step">
        <h2 class="display-md mt-4 mb-3">Algo salió mal</h2>
        <p class="diag-sub mb-8" id="error-msg">Hubo un problema al generar tu diagnóstico. Inténtalo de nuevo o escríbenos por WhatsApp.</p>
        <div class="diag-actions">
          <button type="button" class="btn-secondary" onclick="window.location.reload()">Reintentar</button>
          <a href="https://wa.me/56964261751" target="_blank" rel="noopener noreferrer" class="btn-primary">WhatsApp →</a>
        </div>
      </section>

    </div>
  </main>

  <Footer />
  <WhatsAppButton />
</Layout>

<script define:vars={{ empresaData, procesoData }}>
  // ===== State =====
  const state = {
    step: 'step-intro',
    type: null,    // 'empresa' | 'proceso' | 'ambos'
    mode: null,    // 'express' | 'completo'
    lead: {},
    procesoNombre: '',
    answers: { empresa: {}, proceso: {} },
    sectionIndex: 0,
    sections: [],  // built dynamically based on type
  };

  // ===== Step navigation =====
  function go(stepId) {
    document.querySelectorAll('.diag-step').forEach(el => el.classList.remove('active'));
    const target = document.getElementById(stepId);
    if (target) {
      target.classList.add('active');
      state.step = stepId;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  }

  document.querySelectorAll('.diag-btn-next').forEach(btn => {
    btn.addEventListener('click', () => go(btn.dataset.next));
  });
  document.querySelectorAll('.diag-btn-back').forEach(btn => {
    btn.addEventListener('click', () => go(btn.dataset.back));
  });

  // ===== Lead form =====
  document.getElementById('lead-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    state.lead = {
      nombre: fd.get('nombre').toString().trim(),
      email: fd.get('email').toString().trim(),
      empresa: fd.get('empresa').toString().trim(),
      cargo: (fd.get('cargo') || '').toString().trim(),
      telefono: (fd.get('telefono') || '').toString().trim(),
    };
    go('step-type');
  });

  // ===== Type select =====
  document.querySelectorAll('[data-type]').forEach(card => {
    card.addEventListener('click', () => {
      state.type = card.dataset.type;
      // Update mode time estimates
      const isAmbos = state.type === 'ambos';
      document.getElementById('mode-express-time').textContent = isAmbos ? '~10 minutos · 26 preguntas' : '~5 minutos · 13 preguntas';
      document.getElementById('mode-completo-time').textContent = isAmbos ? '~50 minutos · 104 afirmaciones' : '~25-30 minutos · 52 afirmaciones';
      go('step-mode');
    });
  });

  // ===== Mode select =====
  document.querySelectorAll('[data-mode]').forEach(card => {
    card.addEventListener('click', () => {
      state.mode = card.dataset.mode;
      // If type involves proceso, ask for process name first
      if (state.type === 'proceso' || state.type === 'ambos') {
        go('step-proceso-name');
      } else {
        startQuestions();
      }
    });
  });

  // ===== Proceso name =====
  document.getElementById('proceso-name-form').addEventListener('submit', (e) => {
    e.preventDefault();
    state.procesoNombre = new FormData(e.target).get('procesoNombre').toString().trim();
    startQuestions();
  });

  // ===== Build sections (one per category, for both empresa and proceso if applicable) =====
  function buildSections() {
    const sections = [];

    function addSectionsFor(type, data, prefix) {
      const cats = new Map();
      for (const dim of data) {
        if (!cats.has(dim.category)) cats.set(dim.category, []);
        cats.get(dim.category).push(dim);
      }
      for (const [cat, dims] of cats) {
        sections.push({ type, prefix, category: cat, dimensions: dims });
      }
    }

    if (state.type === 'empresa' || state.type === 'ambos') addSectionsFor('empresa', empresaData, 'E');
    if (state.type === 'proceso' || state.type === 'ambos') addSectionsFor('proceso', procesoData, 'P');

    return sections;
  }

  function startQuestions() {
    state.sections = buildSections();
    state.sectionIndex = 0;
    go('step-questions');
    renderSection();
  }

  // ===== Render current section =====
  function renderSection() {
    const sec = state.sections[state.sectionIndex];
    const total = state.sections.length;
    const idx = state.sectionIndex;

    // Progress bar 60% → 90% across questions
    const pct = 60 + Math.round((idx / total) * 30);
    document.getElementById('questions-progress').style.width = pct + '%';

    document.getElementById('questions-section-label').textContent = `Sección ${idx + 1} de ${total} · ${sec.type === 'empresa' ? 'Empresa' : 'Proceso'}`;
    const procText = (sec.type === 'proceso' && state.procesoNombre) ? ` · ${state.procesoNombre}` : '';
    document.getElementById('questions-title').textContent = sec.category + procText;

    if (state.mode === 'express') {
      document.getElementById('questions-sub').textContent = 'Marca el nivel que mejor describe la realidad actual.';
    } else {
      document.getElementById('questions-sub').textContent = 'Para cada afirmación, indica si es Verde (>80% verdadera), Amarillo (parcial) o Rojo (<20%).';
    }

    const list = document.getElementById('questions-list');
    list.innerHTML = '';

    sec.dimensions.forEach(dim => {
      const dimId = slug(sec.type) + '__' + slug(dim.category) + '__' + slug(dim.dimension);
      const card = document.createElement('div');
      card.className = 'diag-q-card';
      card.dataset.dimId = dimId;

      const title = document.createElement('h4');
      title.className = 'diag-q-title';
      title.textContent = dim.dimension;
      card.appendChild(title);

      if (state.mode === 'express') {
        // Show 4 levels as radio cards
        const opts = document.createElement('div');
        opts.className = 'diag-express-opts';
        ['L1','L2','L3','L4'].forEach((lvl, i) => {
          const lvlNum = i + 1;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'diag-express-opt';
          btn.dataset.level = lvlNum;
          btn.innerHTML = `
            <div class="diag-opt-num">${sec.prefix}-${lvlNum}</div>
            <div class="diag-opt-text">${escapeHtml(dim.statements[lvl])}</div>
          `;
          btn.addEventListener('click', () => {
            opts.querySelectorAll('.diag-express-opt').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            state.answers[sec.type][dimIdShort(sec, dim)] = lvlNum;
          });
          // Restore previous answer
          const stored = state.answers[sec.type][dimIdShort(sec, dim)];
          if (stored === lvlNum) btn.classList.add('selected');
          opts.appendChild(btn);
        });
        card.appendChild(opts);
      } else {
        // Completo: 4 statements with V/A/N
        ['L1','L2','L3','L4'].forEach((lvl, i) => {
          const lvlNum = i + 1;
          const row = document.createElement('div');
          row.className = 'diag-completo-row';
          row.innerHTML = `
            <div class="diag-completo-statement">
              <span class="diag-completo-lvl">${sec.prefix}-${lvlNum}</span>
              <span>${escapeHtml(dim.statements[lvl])}</span>
            </div>
          `;
          const ratings = document.createElement('div');
          ratings.className = 'diag-completo-ratings';
          [['V','Verde','>80%'],['A','Amarillo','20-80%'],['N','Rojo','<20%']].forEach(([code, label, range]) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = `diag-rating diag-rating-${code.toLowerCase()}`;
            btn.dataset.rating = code;
            btn.innerHTML = `<span class="diag-rating-label">${label}</span><span class="diag-rating-range">${range}</span>`;
            btn.addEventListener('click', () => {
              ratings.querySelectorAll('.diag-rating').forEach(b => b.classList.remove('selected'));
              btn.classList.add('selected');
              const id = dimIdShort(sec, dim);
              if (!state.answers[sec.type][id]) state.answers[sec.type][id] = {};
              state.answers[sec.type][id][lvl] = code;
            });
            // Restore
            const stored = state.answers[sec.type][dimIdShort(sec, dim)];
            if (stored && stored[lvl] === code) btn.classList.add('selected');
            ratings.appendChild(btn);
          });
          row.appendChild(ratings);
          card.appendChild(row);
        });
      }
      list.appendChild(card);
    });

    // Buttons state
    const prev = document.getElementById('questions-prev');
    const next = document.getElementById('questions-next');
    prev.disabled = idx === 0;
    next.textContent = (idx === total - 1) ? 'Ver mi diagnóstico →' : 'Siguiente →';
  }

  function dimIdShort(sec, dim) {
    return slug(sec.category) + '__' + slug(dim.dimension);
  }

  function slug(s) {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  function escapeHtml(s) {
    const div = document.createElement('div');
    div.textContent = s || '';
    return div.innerHTML;
  }

  function validateSection() {
    const sec = state.sections[state.sectionIndex];
    for (const dim of sec.dimensions) {
      const id = dimIdShort(sec, dim);
      const ans = state.answers[sec.type][id];
      if (state.mode === 'express') {
        if (!ans) return `Falta responder: ${dim.dimension}`;
      } else {
        if (!ans || !ans.L1 || !ans.L2 || !ans.L3 || !ans.L4) {
          return `Falta calificar las 4 afirmaciones de: ${dim.dimension}`;
        }
      }
    }
    return null;
  }

  document.getElementById('questions-prev').addEventListener('click', () => {
    if (state.sectionIndex > 0) {
      state.sectionIndex--;
      renderSection();
    }
  });

  document.getElementById('questions-next').addEventListener('click', async () => {
    const err = validateSection();
    if (err) {
      alert(err);
      return;
    }
    if (state.sectionIndex < state.sections.length - 1) {
      state.sectionIndex++;
      renderSection();
    } else {
      await submitDiagnostic();
    }
  });

  // ===== Submit =====
  async function submitDiagnostic() {
    go('step-loading');
    setLoadingStep('calc');
    await wait(400);
    setLoadingStep('ai');

    try {
      const res = await fetch('/api/diagnostico', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          lead: state.lead,
          type: state.type,
          mode: state.mode,
          procesoNombre: state.procesoNombre || null,
          answers: state.answers,
        }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || 'server_error');
      }

      const data = await res.json();
      setLoadingStep('email');
      await wait(300);
      renderResult(data);
      go('step-result');
    } catch (err) {
      console.error('[diagnostico] error', err);
      document.getElementById('error-msg').textContent =
        'Hubo un problema al generar tu diagnóstico. Tu información sí se guardó. Inténtalo de nuevo o contáctanos por WhatsApp.';
      go('step-error');
    }
  }

  function setLoadingStep(step) {
    document.querySelectorAll('.diag-loading-step').forEach(el => el.classList.remove('active','done'));
    let reachedActive = false;
    document.querySelectorAll('.diag-loading-step').forEach(el => {
      if (el.dataset.step === step) {
        el.classList.add('active');
        reachedActive = true;
      } else if (!reachedActive) {
        el.classList.add('done');
      }
    });
    const labels = {
      calc: 'Calculando niveles de madurez por dimensión.',
      ai: 'Generando análisis personalizado con IA.',
      email: 'Enviando reporte a tu correo.',
    };
    document.getElementById('loading-status').textContent = labels[step];
  }

  function wait(ms) { return new Promise(r => setTimeout(r, ms)); }

  // ===== Render result =====
  function renderResult(data) {
    const cont = document.getElementById('result-name-display');
    cont.textContent = state.lead.empresa || 'tu empresa';

    document.getElementById('result-sub').textContent = state.procesoNombre
      ? `Análisis de la empresa y del proceso "${state.procesoNombre}".`
      : 'Análisis personalizado generado a partir de tus respuestas.';

    // Scorecards
    const cards = document.getElementById('result-scorecards');
    cards.innerHTML = '';
    (data.results || []).forEach(r => {
      const card = document.createElement('div');
      card.className = 'diag-scorecard';
      card.innerHTML = `
        <div class="diag-scorecard-label">${r.type === 'empresa' ? 'Madurez de Empresa' : `Madurez de Proceso${state.procesoNombre ? ` · ${state.procesoNombre}` : ''}`}</div>
        <div class="diag-scorecard-level">${r.overallLabel}</div>
        <div class="diag-scorecard-score">${r.overallLevel.toFixed(2)} / 4.0</div>
      `;
      cards.appendChild(card);
    });

    // Breakdown
    const bd = document.getElementById('result-breakdown');
    bd.innerHTML = '<h3 class="display-md mb-6" style="font-size:1.5rem;">Desglose por dimensión</h3>';
    (data.results || []).forEach(r => {
      const block = document.createElement('div');
      block.className = 'diag-bd-block';
      let html = `<div class="diag-bd-title">${r.type === 'empresa' ? 'Empresa' : 'Proceso'}</div>`;
      // Group by category
      const byCat = new Map();
      r.dimensions.forEach(d => {
        if (!byCat.has(d.category)) byCat.set(d.category, []);
        byCat.get(d.category).push(d);
      });
      for (const [cat, dims] of byCat) {
        html += `<div class="diag-bd-cat"><div class="diag-bd-cat-title">${cat}</div>`;
        dims.forEach(d => {
          const pct = Math.min(100, (d.level / 4) * 100);
          html += `<div class="diag-bd-row">
            <div class="diag-bd-name">${d.dimension}</div>
            <div class="diag-bd-bar"><div class="diag-bd-bar-fill" style="width:${pct}%"></div></div>
            <div class="diag-bd-level">${d.levelLabel}</div>
          </div>`;
        });
        html += `</div>`;
      }
      block.innerHTML = html;
      bd.appendChild(block);
    });

    // AI diagnostic (HTML safe-rendered)
    const ai = document.getElementById('result-ai');
    ai.innerHTML = `<h3 class="display-md mb-6" style="font-size:1.5rem;">Análisis y recomendaciones</h3>
      <div class="diag-ai-content">${data.diagnosticHtml || '<p>No se pudo generar el análisis.</p>'}</div>`;
  }
</script>

