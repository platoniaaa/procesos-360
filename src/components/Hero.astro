---
---

<section id="hero" class="relative min-h-[100svh] flex items-center overflow-hidden" style="background:var(--night);">

  <!-- Violet aurora mesh background -->
  <div class="absolute inset-0 violet-mesh"></div>

  <!-- Decorative glowing orbs -->

  <!-- Noise overlay -->
  <div class="absolute inset-0 noise-bg"></div>

  <div class="relative z-10 w-full max-w-[1440px] mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-16 md:pb-20">

    <!-- Top label + hairline -->
    <div class="hero-reveal hero-reveal-1 flex items-center gap-4 mb-10 md:mb-16">
      <span class="eyebrow eyebrow-dot" style="color:var(--lilac);">Consultor&iacute;a en gesti&oacute;n por procesos</span>
      <div class="hairline flex-1 max-w-[200px]"></div>
    </div>

    <!-- Headline -->
    <h1 class="hero-reveal hero-reveal-2 hero-headline mb-8 md:mb-10">
      Haz m&aacute;s,
      <br />
      <span class="italic-gradient">mejor</span> y
      <br />
      m&aacute;s r&aacute;pido.
    </h1>

    <!-- Sub + CTAs -->
    <div class="grid grid-cols-12 gap-6 md:gap-10 items-end mb-14 md:mb-20">
      <div class="col-span-12 md:col-span-6">
        <p class="hero-reveal hero-reveal-3 text-lg md:text-xl leading-relaxed max-w-xl" style="color:var(--text-muted);">
          Optimizamos procesos, implementamos IA con criterio y acompa&ntilde;amos el cambio organizacional. Para que la transformaci&oacute;n deje de ser un proyecto y se vuelva tu forma de operar.
        </p>
      </div>

      <div class="hero-reveal hero-reveal-4 col-span-12 md:col-span-6">
        <div class="flex flex-col sm:flex-row gap-3 md:justify-end">
          <a href="/diagnostico" class="btn-primary">
            Hacer diagn&oacute;stico gratis
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="#contacto" class="btn-secondary">Cotiza tu proyecto</a>
        </div>
      </div>
    </div>

    <!-- Trust statement -->
    <div class="hero-reveal hero-reveal-5 pt-8 md:pt-10 border-t" style="border-color:rgba(30,91,255,0.15);">
      <p class="font-display text-xl md:text-3xl leading-tight" style="color:var(--cream);font-weight:400;letter-spacing:-0.02em;">
        <span class="italic-accent">Empresas</span> que han confiado en nosotros.
      </p>
    </div>
  </div>
</section>

<style>
  .hero-headline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3.25rem, 12vw, 10.5rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
    color: var(--cream);
  }
</style>
