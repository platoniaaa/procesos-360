const items = [
  {
    label: 'Nuestra visión',
    desc: `<p>Ser el <strong>socio estratégico</strong> de nuestros clientes en su viaje hacia la excelencia operativa y el crecimiento sostenible. Aspiramos a ser reconocidos como líderes en la transformación empresarial a través de la excelencia en la gestión por procesos, alineando los procesos de las organizaciones con sus objetivos estratégicos.</p>`,
  },
  {
    label: 'Nuestra misión',
    desc: `<p>Colaborar estrechamente con nuestros clientes para <strong>mejorar su rendimiento operativo</strong>, maximizar su eficiencia y fomentar una cultura de mejora continua en toda su organización. Cada proceso es una oportunidad para innovar y agregar valor.</p>`,
  },
  {
    label: 'Nuestro enfoque',
    desc: `<p>Creemos en un <strong>enfoque holístico</strong> de la gestión por procesos que combine la experiencia técnica con un profundo entendimiento del negocio y un compromiso con las personas. Nos esforzamos por comprender las necesidades únicas de cada cliente y desarrollar soluciones personalizadas que generen resultados tangibles y sostenibles.</p>`,
  },
  {
    label: 'Nuestros valores',
    desc: `<ul class="about-list">
      <li><strong>Integridad.</strong> Honestos en cada decisión, transparentes en cada interacción.</li>
      <li><strong>Excelencia.</strong> El estándar más alto en cada proceso, cada entregable, cada conversación.</li>
      <li><strong>Colaboración.</strong> Trabajamos lado a lado con tu equipo, nunca por encima.</li>
      <li><strong>Compromiso.</strong> Nos hacemos parte del éxito a largo plazo de tu organización.</li>
    </ul>`,
  },
  {
    label: 'Nuestro compromiso',
    desc: `<p>Estamos comprometidos a establecer <strong>relaciones sólidas y duraderas</strong> con nuestros clientes, basadas en la confianza mutua, la transparencia y los resultados medibles. Nos consideramos socios estratégicos en su viaje hacia la excelencia operativa y estamos dedicados a su éxito a largo plazo.</p>`,
  },
  {
    label: 'Nuestros pilares',
    desc: `<ul class="about-list">
      <li><strong>Comprensión del negocio.</strong> Poseemos un profundo entendimiento del negocio de sus clientes, incluyendo sus objetivos estratégicos, estructura organizativa, cultura empresarial y desafíos específicos.</li>
      <li><strong>Experiencia en gestión por procesos.</strong> Contamos con experiencia y conocimientos sólidos en metodologías de gestión por procesos, como Lean Management, BPM (Business Process Management), entre otras, para poder ofrecer soluciones efectivas y personalizadas a sus clientes.</li>
      <li><strong>Enfoque centrado en el cliente.</strong> Ponemos al cliente en el centro de sus acciones y desarrolle soluciones que estén alineadas con sus necesidades y objetivos empresariales.</li>
      <li><strong>Tecnología y herramientas adecuadas.</strong> Estamos al tanto de las últimas tendencias tecnológicas y herramientas disponibles para la optimización de procesos, y ser capaz de recomendar e implementar aquellas que mejor se adapten a las necesidades de sus clientes.</li>
      <li><strong>Desarrollo del talento humano.</strong> Reconocemos la importancia del factor humano en la gestión por procesos, por lo que promovemos el desarrollo profesional de los colaboradores de sus clientes, ofreciendo capacitación y apoyo para mejorar sus habilidades y competencias en la gestión de procesos.</li>
      <li><strong>Enfoque en la mejora continua.</strong> Adoptamos una mentalidad de mejora continua, trabajando en colaboración con sus clientes para identificar oportunidades de optimización y desarrollar soluciones que impulsen la eficiencia y la innovación en sus procesos empresariales.</li>
    </ul>`,
  },
];
---

<section id="nosotros-detalle" class="relative py-20 md:py-32 overflow-hidden" style="background:var(--midnight);">

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- 10 años badge -->
    <div class="mb-12 md:mb-20 fade-up">
      <div class="experience-badge">
        <div class="experience-num">10</div>
        <div class="experience-label">a&ntilde;os de<br/>experiencia</div>
      </div>
    </div>

    <!-- Bloque interactivo (formato "¿Qué hacemos?") -->
    <div class="grid grid-cols-12 gap-8 md:gap-12 lg:gap-20">

      <!-- LEFT — heading + descripción dinámica -->
      <div class="col-span-12 lg:col-span-5 fade-up">
        <h2 class="about-heading">Nuestra esencia</h2>
        <div id="about-desc" class="about-desc" set:html={items[0].desc}></div>
        <a href="#contacto" class="about-cta">Conversemos</a>
      </div>

      <!-- RIGHT — lista interactiva -->
      <div class="col-span-12 lg:col-span-7 fade-up" style="transition-delay:120ms;">
        <div class="about-nav">
          {items.map((it, i) => (
            <button
              type="button"
              class:list={['about-item', { 'is-active': i === 0 }]}
              data-index={i}
              data-desc={it.desc}
            >
              {it.label}
            </button>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>('.about-item');
  const descEl = document.getElementById('about-desc');
  let activeIndex = 0;

  function setActive(item: HTMLButtonElement) {
    const idx = Number(item.dataset.index);
    if (idx === activeIndex) return;
    activeIndex = idx;

    items.forEach((el) => el.classList.toggle('is-active', el === item));

    if (descEl) {
      descEl.classList.add('is-swapping');
      window.setTimeout(() => {
        descEl.innerHTML = item.dataset.desc || '';
        descEl.classList.remove('is-swapping');
      }, 160);
    }
  }

  items.forEach((item) => {
    item.addEventListener('mouseenter', () => setActive(item));
    item.addEventListener('click', () => setActive(item));
    item.addEventListener('focus', () => setActive(item));
  });
</script>

<style>
  .about-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--plum);
    margin: 0 0 1.75rem;
  }

  .about-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 2.25rem;
    min-height: 11rem;
    transition: opacity 0.16s ease;
  }
  .about-desc.is-swapping { opacity: 0; }
  .about-desc :global(p) { margin: 0; }
  .about-desc :global(strong) { color: var(--cream); font-weight: 600; }
  .about-desc :global(.about-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .about-desc :global(.about-list li) {
    position: relative;
    padding-left: 1.4rem;
  }
  .about-desc :global(.about-list li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lilac);
  }

  .about-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: #FFFFFF;
    background: var(--plum);
    padding: 0.9rem 2.25rem;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
  }
  .about-cta:hover { transform: translateY(-2px); background: var(--violet); }

  /* --- Right list — Olivia-style --- */
  .about-nav {
    display: flex;
    flex-direction: column;
  }
  .about-item {
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(30, 91, 255, 0.16);
    padding: 0.85rem 0;
    cursor: pointer;
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.25rem, 2.8vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    transition: color 0.25s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .about-item:first-child { border-top: 1px solid rgba(30, 91, 255, 0.16); }
  @media (min-width: 768px) {
    .about-item { padding: 1.05rem 0; }
  }

  .about-item:hover,
  .about-item.is-active {
    color: var(--plum);
  }

  /* --- Experience badge --- */
  .experience-badge {
    width: 200px;
    height: 200px;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--plum) 0%, var(--violet) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #FFFFFF;
    box-shadow: 0 16px 40px rgba(30, 91, 255, 0.25);
    position: relative;
    overflow: hidden;
  }
  .experience-badge::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -40%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(41, 201, 214, 0.4) 0%, transparent 70%);
    pointer-events: none;
  }

  .experience-num {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 5rem;
    line-height: 1;
    letter-spacing: -0.04em;
    position: relative;
    z-index: 1;
  }

  .experience-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-align: center;
    margin-top: 0.5rem;
    opacity: 0.95;
    line-height: 1.4;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .experience-badge {
      width: 160px;
      height: 160px;
      margin: 0 auto;
    }
    .experience-num { font-size: 4rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-item, .about-desc, .about-cta { transition: none; }
  }
</style>
