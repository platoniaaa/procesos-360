---
const clients = [
  { name: 'Derco',                       logo: '/img/clients/derco.png' },
  { name: 'Copec',                       logo: '/img/clients/copec.png' },
  { name: 'Transbank',                   logo: '/img/clients/transbank.png' },
  { name: 'Caserones',                   logo: '/img/clients/caserones.png' },
  { name: 'Gallagher',                   logo: '/img/clients/gallagher.jpg' },
  { name: 'CFT Estatal Región Metropolitana', logo: '/img/clients/cft-rm.png' },
  { name: 'FACM',                        logo: '/img/clients/facm.jpg' },
  { name: 'Unired',                      logo: '/img/clients/unired.png' },
  { name: 'Sercomed',                    logo: '/img/clients/sercomed.png' },
  { name: '.vgroup',                     logo: '/img/clients/vgroup.png' },
  { name: 'Facultad de Economía y Negocios — U. de Chile', logo: '/img/clients/fen-uchile.jpg' },
  { name: 'UDLA',                        logo: '/img/clients/udla.png' },
  { name: 'Universidad del Desarrollo',  logo: '/img/clients/udd.jpg' },
  { name: 'SONAMI',                      logo: '/img/clients/sonami.png' },
  { name: 'Arcoprime',                   logo: '/img/clients/arcoprime.png' },
  { name: 'Proyectum',                   logo: '/img/clients/proyectum.png' },
  { name: 'Empresa Eléctrica Municipal de TilTil', logo: '/img/clients/eemtt.jpg' },
  { name: 'ProntoPaga',                  logo: '/img/clients/prontopaga.png' },
  { name: 'SURA',                        logo: '/img/clients/sura.png' },
  { name: 'MSO',                         logo: '/img/clients/mso.jpg' },
];

// Repartimos en dos filas con logos distintos
const rowA = clients.filter((_, i) => i % 2 === 0);
const rowB = clients.filter((_, i) => i % 2 === 1);
---

<section class="trust-section" aria-label="Nuestros clientes">
  <!-- Header al estilo Olivia: título gigante + parrafo + CTA -->
  <div class="trust-header">
    <div class="trust-header-inner">
      <div class="eyebrow eyebrow-dot trust-eyebrow">Nuestros clientes</div>
      <h2 class="trust-title">
        Por ellos<br/>nos la <span class="trust-title-accent">jugamos</span>.
      </h2>
      <div class="trust-bottom">
        <p class="trust-lead">
          Nuestros clientes comparten un denominador com&uacute;n: enfrentar grandes desaf&iacute;os. Nos la jugamos por ellos para que puedan hacerlos realidad.
        </p>
        <a href="/clientes" target="_blank" rel="noopener" class="trust-cta">
          Con&oacute;celos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Marquee: 2 filas, direcciones opuestas -->
  <div class="trust-marquees">
    <div class="marquee">
      <div class="marquee-track marquee-left">
        {[...rowA, ...rowA].map((c) => (
          <div class="marquee-item">
            <img src={c.logo} alt={c.name} class="trust-logo" loading="lazy" draggable="false" />
          </div>
        ))}
      </div>
    </div>

    <div class="marquee marquee-row-2">
      <div class="marquee-track marquee-right">
        {[...rowB, ...rowB].map((c) => (
          <div class="marquee-item">
            <img src={c.logo} alt={c.name} class="trust-logo" loading="lazy" draggable="false" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .trust-section {
    background: #0A1F4A;
    color: #FFFFFF;
    padding: 5rem 0 4rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .trust-section { padding: 7rem 0 5rem; }
  }

  /* ---------- HEADER ---------- */
  .trust-header {
    padding: 0 1.5rem;
    margin-bottom: 3.5rem;
  }
  @media (min-width: 768px) {
    .trust-header { padding: 0 4rem; margin-bottom: 5rem; }
  }

  .trust-header-inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  .trust-eyebrow {
    color: var(--lilac);
    display: inline-block;
    margin-bottom: 1.25rem;
  }

  .trust-title {
    font-family: var(--font-condensed);
    font-weight: 400; /* Anton es bold por defecto */
    font-size: clamp(3.5rem, 13vw, 11rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: #FFFFFF;
    margin: 0 0 2.5rem;
    text-transform: uppercase;
  }
  .trust-title-accent {
    color: var(--lilac);
    font-style: normal;
  }

  .trust-bottom {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
    align-items: end;
    max-width: 1100px;
  }
  @media (min-width: 900px) {
    .trust-bottom {
      grid-template-columns: 1.4fr auto;
      gap: 3rem;
    }
  }

  .trust-lead {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
    max-width: 50rem;
  }

  .trust-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.95rem 2rem;
    background: var(--lilac);
    color: #0A1F4A;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border-radius: 999px;
    transition: transform 0.3s, background 0.3s;
    white-space: nowrap;
    align-self: start;
  }
  .trust-cta:hover {
    transform: translateY(-2px);
    background: var(--lilac-soft);
  }

  /* ---------- MARQUEES ---------- */
  .trust-marquees {
    margin-top: 1rem;
  }

  .marquee {
    overflow: hidden;
    width: 100%;
  }
  .marquee-row-2 { margin-top: 0.75rem; }
  @media (min-width: 768px) {
    .marquee-row-2 { margin-top: 1rem; }
  }

  .marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .marquee-left  { animation: marquee-x-left  38s linear infinite; }
  .marquee-right { animation: marquee-x-right 38s linear infinite; }

  @media (max-width: 768px) {
    .marquee-left,
    .marquee-right { animation-duration: 24s; }
  }

  @keyframes marquee-x-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes marquee-x-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  /* Cada logo va en una mini-tarjeta translúcida — así los logos JPG
     con fondo blanco también quedan legibles sobre el navy. */
  .marquee-item {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 0.6rem;
    width: 168px;
    height: 76px;
    padding: 12px 20px;
    flex-shrink: 0;
    background: #FFFFFF;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    transition: transform 0.3s, border-color 0.3s;
  }
  @media (min-width: 768px) {
    .marquee-item {
      margin: 0 0.75rem;
      width: 200px;
      height: 92px;
      padding: 14px 24px;
    }
  }
  .marquee-item:hover {
    border-color: rgba(41, 201, 214, 0.6);
    transform: translateY(-2px);
  }

  .trust-logo {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-left,
    .marquee-right { animation: none; }
  }
</style>
