---
const clients = [
  { name: 'Derco',                       logo: '/img/clients/derco.png' },
  { name: 'Copec',                       logo: '/img/clients/copec.png' },
  { name: 'Transbank',                   logo: '/img/clients/transbank.png' },
  { name: 'Caserones',                   logo: '/img/clients/caserones.png' },
  { name: 'Gallagher',                   logo: '/img/clients/gallagher.jpg' },
  { name: 'CFT Estatal Región Metropolitana', logo: '/img/clients/cft-rm.png' },
  { name: 'FACM',                        logo: '/img/clients/facm.jpg' },
  { name: 'Unired',                      logo: '/img/clients/unired.png' },
  { name: 'Sercomed',                    logo: '/img/clients/sercomed.png' },
  { name: '.vgroup',                     logo: '/img/clients/vgroup.png' },
  { name: 'Facultad de Economía y Negocios — U. de Chile', logo: '/img/clients/fen-uchile.jpg' },
  { name: 'UDLA',                        logo: '/img/clients/udla.png' },
  { name: 'Universidad del Desarrollo',  logo: '/img/clients/udd.jpg' },
  { name: 'SONAMI',                      logo: '/img/clients/sonami.png' },
  { name: 'Arcoprime',                   logo: '/img/clients/arcoprime.png' },
  { name: 'Proyectum',                   logo: '/img/clients/proyectum.png' },
  { name: 'Empresa Eléctrica Municipal de TilTil', logo: '/img/clients/eemtt.jpg' },
  { name: 'ProntoPaga',                  logo: '/img/clients/prontopaga.png' },
  { name: 'SURA',                        logo: '/img/clients/sura.png' },
  { name: 'MSO',                         logo: '/img/clients/mso.jpg' },
];

// Reparto en dos filas para que cada una tenga logos distintos
const rowA = clients.filter((_, i) => i % 2 === 0);
const rowB = clients.filter((_, i) => i % 2 === 1);
---

<section class="trust-section" aria-label="Empresas que han confiado en nosotros">

  <!-- Header al estilo Olivia: titulo GIGANTE + parrafo + boton -->
  <div class="trust-header fade-up">
    <div class="trust-header-inner">
      <h2 class="trust-title">
        Por ellos<br/>nos la <span class="trust-title-accent">jugamos</span>.
      </h2>
      <div class="trust-right">
        <p class="trust-lead">
          Nuestros clientes comparten un denominador com&uacute;n: enfrentar grandes desaf&iacute;os. Nos la jugamos por ellos para que puedan hacerlos realidad.
        </p>
        <a href="/clientes" target="_blank" rel="noopener" class="trust-cta">
          Con&oacute;celos
        </a>
      </div>
    </div>
  </div>

  <!-- Logos en dos filas — fila 1 se mueve a la izquierda, fila 2 a la derecha -->
  <div class="trust-marquees">
    <div class="marquee">
      <div class="marquee-track marquee-left">
        {[...rowA, ...rowA].map((c) => (
          <div class="marquee-item">
            <img src={c.logo} alt={c.name} class="trust-logo" loading="lazy" draggable="false" />
          </div>
        ))}
      </div>
    </div>
    <div class="marquee marquee-row-2">
      <div class="marquee-track marquee-right">
        {[...rowB, ...rowB].map((c) => (
          <div class="marquee-item">
            <img src={c.logo} alt={c.name} class="trust-logo" loading="lazy" draggable="false" />
          </div>
        ))}
      </div>
    </div>
  </div>

</section>

<style>
  .trust-section {
    background: var(--night);
    padding: 5rem 0 3rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .trust-section { padding: 7rem 0 4rem; }
  }

  /* --- Header con tipografia condensada estilo Olivia --- */
  .trust-header {
    padding: 0 1.5rem 3rem;
  }
  @media (min-width: 768px) {
    .trust-header { padding: 0 4rem 4.5rem; }
  }

  .trust-header-inner {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: end;
  }
  @media (min-width: 900px) {
    .trust-header-inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
    }
  }

  .trust-title {
    font-family: var(--font-condensed);
    font-weight: 400;
    font-size: clamp(3.5rem, 12vw, 11rem);
    line-height: 0.88;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--cream);
    margin: 0;
  }
  .trust-title-accent {
    color: var(--lilac);
  }

  .trust-right {
    padding-bottom: 0.75rem;
  }
  .trust-lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0 0 1.75rem;
    max-width: 32rem;
  }
  @media (min-width: 768px) {
    .trust-lead { font-size: 1.05rem; }
  }
  .trust-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--cream);
    background: transparent;
    border: 1.5px solid var(--cream);
    padding: 0.85rem 2.25rem;
    border-radius: 999px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .trust-cta:hover {
    background: var(--lilac);
    border-color: var(--lilac);
    color: var(--night);
  }

  /* --- Marquees --- */
  .trust-marquees {
    padding: 2rem 0;
    border-top: 1px solid rgba(30, 91, 255, 0.10);
    border-bottom: 1px solid rgba(30, 91, 255, 0.10);
    background: #FFFFFF;
  }

  .marquee {
    overflow: hidden;
    width: 100%;
  }
  .marquee-row-2 { margin-top: 0.75rem; }
  @media (min-width: 768px) {
    .marquee-row-2 { margin-top: 1rem; }
  }

  .marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .marquee-left  { animation: marquee-x-left  38s linear infinite; }
  .marquee-right { animation: marquee-x-right 38s linear infinite; }

  @media (max-width: 768px) {
    .marquee-left,
    .marquee-right { animation-duration: 24s; }
  }

  @keyframes marquee-x-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes marquee-x-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  .marquee-item {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 1.75rem;
    height: 56px;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .marquee-item {
      margin: 0 2.5rem;
      height: 64px;
    }
  }

  .trust-logo {
    max-height: 100%;
    max-width: 160px;
    width: auto;
    height: auto;
    object-fit: contain;
    pointer-events: none;
    filter: saturate(0.85);
    opacity: 0.92;
    transition: filter 0.3s, opacity 0.3s;
  }
  @media (min-width: 768px) {
    .trust-logo { max-width: 180px; }
  }
  .marquee:hover .trust-logo {
    filter: saturate(1);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-left,
    .marquee-right { animation: none; }
  }
</style>
