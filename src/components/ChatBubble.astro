---
import isotipo from '../assets/img/isotipo.png';
---

<button id="chat-bubble" class="chat-bubble touch-manipulation" aria-label="Abrir asistente IA Platonia" type="button">
  <span class="chat-bubble-pulse"></span>
  <img src={isotipo.src} alt="Platonia" class="chat-bubble-isotipo" />
  <span class="chat-bubble-badge">IA</span>
</button>

<div id="chat-bubble-tooltip" class="chat-bubble-tooltip" role="dialog">
  <button id="chat-bubble-tooltip-close" class="chat-bubble-tooltip-close" aria-label="Cerrar" type="button">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <div class="chat-bubble-tooltip-text">
    <div class="chat-bubble-tooltip-title">¿Necesitas ayuda?</div>
    <div class="chat-bubble-tooltip-sub">Cuéntale tu desafío a nuestra IA y recibe un diagnóstico gratis.</div>
  </div>
</div>

<script>
  const bubble = document.getElementById('chat-bubble')!;
  const tooltip = document.getElementById('chat-bubble-tooltip')!;
  const tooltipClose = document.getElementById('chat-bubble-tooltip-close')!;

  // Trigger chat fullscreen via custom event
  function openChat() {
    document.dispatchEvent(new CustomEvent('platonia:open-chat'));
    hideTooltip();
  }

  bubble.addEventListener('click', openChat);

  // Tooltip logic: show after 8s, hide on dismiss or when bubble clicked
  const TOOLTIP_KEY = 'platonia_bubble_tooltip_dismissed';
  function showTooltip() {
    if (sessionStorage.getItem(TOOLTIP_KEY)) return;
    tooltip.classList.add('visible');
  }
  function hideTooltip() {
    tooltip.classList.remove('visible');
    sessionStorage.setItem(TOOLTIP_KEY, '1');
  }

  tooltipClose.addEventListener('click', (e) => {
    e.stopPropagation();
    hideTooltip();
  });
  tooltip.addEventListener('click', () => openChat());

  // Show tooltip after 8 seconds (only first session)
  setTimeout(() => {
    showTooltip();
    // Auto-hide after 10s if user doesn't interact
    setTimeout(() => {
      tooltip.classList.remove('visible');
    }, 10000);
  }, 8000);

  // Hide bubble when chat is open in fullscreen
  const observer = new MutationObserver(() => {
    const chatOpen = document.body.classList.contains('chat-fullscreen-open');
    bubble.style.opacity = chatOpen ? '0' : '1';
    bubble.style.pointerEvents = chatOpen ? 'none' : 'auto';
    if (chatOpen) tooltip.classList.remove('visible');
  });
  observer.observe(document.body, { attributes: true, attributeFilter: ['class'] });
</script>

<style>
  .chat-bubble {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 60;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1px solid rgba(216, 180, 254, 0.3);
    background: linear-gradient(135deg, var(--lilac) 0%, var(--plum) 100%);
    color: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 8px 28px rgba(107, 33, 168, 0.45);
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    -webkit-tap-highlight-color: transparent;
    overflow: visible;
  }
  @media (min-width: 768px) {
    .chat-bubble {
      bottom: 1.75rem;
      right: 1.75rem;
      width: 56px;
      height: 56px;
    }
  }
  .chat-bubble:hover {
    transform: scale(1.08);
    box-shadow: 0 14px 40px rgba(168, 85, 247, 0.55);
  }
  .chat-bubble:active {
    transform: scale(0.96);
  }

  .chat-bubble-pulse {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: rgba(168, 85, 247, 0.35);
    animation: bubble-pulse 2.5s ease-out infinite;
    pointer-events: none;
  }
  @keyframes bubble-pulse {
    0% { transform: scale(0.95); opacity: 0.55; }
    70% { transform: scale(1.5); opacity: 0; }
    100% { transform: scale(1.5); opacity: 0; }
  }

  /* Real Platonia isotipo image */
  .chat-bubble-isotipo {
    width: 28px;
    height: 28px;
    object-fit: contain;
    /* Make the isotipo white on the violet background */
    filter: brightness(0) invert(1);
  }
  @media (min-width: 768px) {
    .chat-bubble-isotipo {
      width: 30px;
      height: 30px;
    }
  }

  /* "IA" badge in the corner */
  .chat-bubble-badge {
    position: absolute;
    top: -4px;
    right: -6px;
    background: var(--gold);
    color: var(--night);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 999px;
    border: 2px solid var(--night);
    line-height: 1;
    z-index: 2;
  }
  @media (min-width: 768px) {
    .chat-bubble-badge {
      font-size: 0.6rem;
      padding: 3px 7px;
      top: -5px;
      right: -7px;
    }
  }

  /* Tooltip */
  .chat-bubble-tooltip {
    position: fixed;
    bottom: calc(1.25rem + 52px + 16px);
    right: 1.25rem;
    z-index: 59;
    width: 280px;
    max-width: calc(100vw - 2.5rem);
    background: var(--midnight);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 16px;
    padding: 16px 18px;
    padding-right: 36px;
    color: var(--cream);
    box-shadow: 0 20px 60px rgba(107, 33, 168, 0.4);
    font-family: var(--font-sans);
    cursor: pointer;
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (min-width: 768px) {
    .chat-bubble-tooltip {
      bottom: calc(1.75rem + 56px + 16px);
      right: 1.75rem;
    }
  }
  .chat-bubble-tooltip.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .chat-bubble-tooltip::after {
    content: '';
    position: absolute;
    bottom: -7px;
    right: 25px;
    width: 14px;
    height: 14px;
    background: var(--midnight);
    border-right: 1px solid rgba(168, 85, 247, 0.3);
    border-bottom: 1px solid rgba(168, 85, 247, 0.3);
    transform: rotate(45deg);
  }
  .chat-bubble-tooltip-title {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 4px;
    font-family: var(--font-display);
  }
  .chat-bubble-tooltip-sub {
    font-size: 13px;
    line-height: 1.45;
    color: var(--text-muted);
  }
  .chat-bubble-tooltip-close {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.2s;
  }
  .chat-bubble-tooltip-close:hover {
    background: rgba(216, 180, 254, 0.1);
    color: var(--cream);
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-bubble-pulse { animation: none; opacity: 0; }
  }
</style>
