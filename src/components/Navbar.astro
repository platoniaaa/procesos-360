---
import logoCompleto from '../assets/img/logo-completo.png';
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="#" class="flex-shrink-0 relative z-[70]">
        <img id="navbar-logo" src={logoCompleto.src} alt="Procesos 360" class="h-8 md:h-9 w-auto transition-all duration-300" />
      </a>

      <div class="hidden md:flex items-center gap-9">
        <a href="/#servicios" class="nav-link text-sm transition-colors duration-300">Servicios</a>
        <a href="/#productos" class="nav-link text-sm transition-colors duration-300">Productos</a>
        <a href="/diagnostico" class="nav-link text-sm transition-colors duration-300">
          <span style="background:linear-gradient(135deg, var(--lilac), var(--plum));background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-style:italic;font-family:var(--font-display);">Diagn&oacute;stico</span>
        </a>
        <a href="/#por-que-procesos360" class="nav-link text-sm transition-colors duration-300">Por qu&eacute;</a>
        <a href="/#nosotros" class="nav-link text-sm transition-colors duration-300">Nosotros</a>
        <a href="/#contacto" class="btn-primary !py-2 !px-5 !text-xs">Cotiza gratis</a>
      </div>

      <button id="menu-toggle" class="md:hidden p-3 -mr-2 relative z-[70] touch-manipulation" aria-label="Abrir menú" style="color:var(--cream);">
        <div id="hamburger" class="w-6 h-5 relative flex flex-col justify-between">
          <span class="hamburger-line w-full h-0.5 transition-all duration-300 origin-center" style="background:currentColor;"></span>
          <span class="hamburger-line w-full h-0.5 transition-all duration-300" style="background:currentColor;"></span>
          <span class="hamburger-line w-full h-0.5 transition-all duration-300 origin-center" style="background:currentColor;"></span>
        </div>
      </button>
    </div>
  </div>
</nav>

<div id="mobile-menu" class="mobile-menu-overlay md:hidden" style="display:none;">
  <button id="mobile-close" class="mobile-menu-close touch-manipulation" aria-label="Cerrar menú">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <div class="mobile-menu-content">
    <div class="marginalia mb-8" style="color:var(--lilac);">&Iacute;ndice</div>
    <a href="/#servicios" class="mobile-link">Servicios</a>
    <a href="/#productos" class="mobile-link">Productos</a>
    <a href="/diagnostico" class="mobile-link" style="background:linear-gradient(135deg, var(--lilac), var(--plum));background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-style:italic;">Diagn&oacute;stico</a>
    <a href="/#por-que-procesos360" class="mobile-link">&iquest;Por qu&eacute; Procesos 360?</a>
    <a href="/#nosotros" class="mobile-link">Nosotros</a>
    <a href="/#contacto" class="mobile-link">Contacto</a>
    <a href="/#contacto" class="btn-primary !py-3.5 !px-10 !text-base mt-6 touch-manipulation">Cotiza gratis</a>
  </div>
</div>

<script>
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.querySelectorAll('.nav-link');
  let menuOpen = false;

  function updateNavbar() {
    if (!navbar) return;
    const scrolled = window.scrollY > 30;
    if (scrolled && !menuOpen) {
      navbar.style.background = 'rgba(255, 255, 255, 0.85)';
      (navbar.style as any).backdropFilter = 'blur(16px)';
      (navbar.style as any).webkitBackdropFilter = 'blur(16px)';
      navbar.style.borderBottom = '1px solid rgba(30, 91, 255, 0.10)';
    } else if (!menuOpen) {
      navbar.style.background = 'transparent';
      (navbar.style as any).backdropFilter = 'none';
      (navbar.style as any).webkitBackdropFilter = 'none';
      navbar.style.borderBottom = 'none';
    }
  }

  updateNavbar();
  window.addEventListener('scroll', updateNavbar);

  menuToggle?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      if (mobileMenu) mobileMenu.style.display = 'flex';
      hamburger?.classList.add('open');
      document.body.style.overflow = 'hidden';
    } else closeMenu();
  });

  function closeMenu() {
    menuOpen = false;
    if (mobileMenu) mobileMenu.style.display = 'none';
    hamburger?.classList.remove('open');
    document.body.style.overflow = '';
    updateNavbar();
  }

  document.querySelectorAll('.mobile-link').forEach(link => link.addEventListener('click', closeMenu));
  document.getElementById('mobile-close')?.addEventListener('click', closeMenu);

  const sections = document.querySelectorAll('section[id]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => {
            if (link.getAttribute('href') === `#${entry.target.id}`) link.classList.add('!font-semibold');
            else link.classList.remove('!font-semibold');
          });
        }
      });
    },
    { rootMargin: '-20% 0px -80% 0px' }
  );
  sections.forEach(section => observer.observe(section));
</script>

<style>
  .nav-link {
    position: relative;
    color: var(--cream);
    opacity: 0.85;
    transition: opacity 0.3s;
  }
  .nav-link:hover { opacity: 1; }

  #hamburger.open .hamburger-line:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  #hamburger.open .hamburger-line:nth-child(2) { opacity: 0; }
  #hamburger.open .hamburger-line:nth-child(3) { transform: rotate(-45deg) translate(6px, -6px); }

  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    z-index: 60;
    background: var(--night);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .mobile-menu-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
  }

  .mobile-menu-content .mobile-link {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: var(--cream);
    text-decoration: none;
    padding: 0.25rem 1rem;
    letter-spacing: -0.03em;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .mobile-menu-content .mobile-link:active { color: var(--lilac); }

  .mobile-menu-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(30, 91, 255, 0.25);
    border-radius: 50%;
    cursor: pointer;
    color: var(--cream);
    z-index: 65;
    -webkit-tap-highlight-color: transparent;
  }
  .mobile-menu-close:active { background: rgba(41, 201, 214, 0.15); }
</style>
