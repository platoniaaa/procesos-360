---
import logoCompleto from '../assets/img/logo-completo.png';

const links = [
  { label: 'Servicios',   href: '/#servicios' },
  { label: 'Productos',   href: '/#productos' },
  { label: 'Diagnóstico', href: '/diagnostico' },
  { label: 'Casos de éxito', href: '/#casos' },
  { label: 'Por qué',     href: '/#por-que-procesos360' },
  { label: 'Nosotros',    href: '/nosotros' },
  { label: 'Contacto',    href: '/#contacto' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-[70] transition-all duration-500">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex-shrink-0 relative">
        <img id="navbar-logo" src={logoCompleto.src} alt="Procesos 360" class="h-8 md:h-9 w-auto transition-all duration-300" />
      </a>

      <div class="navbar-actions">
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Activar modo oscuro">
          <svg class="theme-icon theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          <svg class="theme-icon theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>

        <button id="menu-toggle" class="menu-toggle" aria-label="Abrir menú" aria-expanded="false">
          <span id="menu-toggle-label" class="menu-toggle-label">Menú</span>
          <div id="hamburger" class="w-6 h-5 relative flex flex-col justify-between">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
          </div>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- Fullscreen menu -->
<div id="fs-menu" class="fs-menu" aria-hidden="true">
  <nav class="fs-menu-nav">
    {links.map((link) => (
      <a href={link.href} class="fs-link">{link.label}</a>
    ))}
  </nav>
  <div class="fs-menu-footer">
    <a href="/#contacto" class="fs-cta">Cotiza gratis &rarr;</a>
    <div class="fs-menu-meta">
      <a href="https://wa.me/56964261751" target="_blank" rel="noopener noreferrer">+569 64261751</a>
      <span>&middot;</span>
      <a href="mailto:javier.espinoza@procesos360.cl">javier.espinoza@procesos360.cl</a>
    </div>
  </div>
</div>

<script>
  const navbar = document.getElementById('navbar');
  const logo = document.getElementById('navbar-logo') as HTMLImageElement | null;
  const menuToggle = document.getElementById('menu-toggle');
  const menuToggleLabel = document.getElementById('menu-toggle-label');
  const hamburger = document.getElementById('hamburger');
  const fsMenu = document.getElementById('fs-menu');
  let menuOpen = false;

  // Logo turns white over a dark surface (menu overlay or dark theme)
  function updateLogo() {
    if (!logo) return;
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    logo.style.filter = (menuOpen || isDark) ? 'brightness(0) invert(1)' : '';
  }
  updateLogo();

  function updateNavbar() {
    if (!navbar) return;
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (menuOpen) {
      navbar.style.background = 'transparent';
      (navbar.style as any).backdropFilter = 'none';
      (navbar.style as any).webkitBackdropFilter = 'none';
      navbar.style.borderBottom = 'none';
      return;
    }
    const scrolled = window.scrollY > 30;
    if (scrolled) {
      navbar.style.background = isDark ? 'rgba(10, 31, 74, 0.85)' : 'rgba(255, 255, 255, 0.85)';
      (navbar.style as any).backdropFilter = 'blur(16px)';
      (navbar.style as any).webkitBackdropFilter = 'blur(16px)';
      navbar.style.borderBottom = isDark
        ? '1px solid rgba(255, 255, 255, 0.10)'
        : '1px solid rgba(30, 91, 255, 0.10)';
    } else {
      navbar.style.background = 'transparent';
      (navbar.style as any).backdropFilter = 'none';
      (navbar.style as any).webkitBackdropFilter = 'none';
      navbar.style.borderBottom = 'none';
    }
  }
  updateNavbar();
  window.addEventListener('scroll', updateNavbar);

  function openMenu() {
    menuOpen = true;
    fsMenu?.classList.add('is-open');
    fsMenu?.setAttribute('aria-hidden', 'false');
    hamburger?.classList.add('open');
    menuToggle?.setAttribute('aria-expanded', 'true');
    if (menuToggleLabel) menuToggleLabel.textContent = 'Cerrar';
    document.body.classList.add('menu-open');
    document.body.style.overflow = 'hidden';
    updateNavbar();
    updateLogo();
  }

  function closeMenu() {
    menuOpen = false;
    fsMenu?.classList.remove('is-open');
    fsMenu?.setAttribute('aria-hidden', 'true');
    hamburger?.classList.remove('open');
    menuToggle?.setAttribute('aria-expanded', 'false');
    if (menuToggleLabel) menuToggleLabel.textContent = 'Menú';
    document.body.classList.remove('menu-open');
    document.body.style.overflow = '';
    updateNavbar();
    updateLogo();
  }

  menuToggle?.addEventListener('click', () => {
    menuOpen ? closeMenu() : openMenu();
  });

  document.querySelectorAll('.fs-link, .fs-cta').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) closeMenu();
  });

  /* --- Theme toggle --- */
  const themeToggle = document.getElementById('theme-toggle');

  function currentTheme() {
    return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
  }
  function syncThemeUI() {
    if (themeToggle) {
      themeToggle.setAttribute(
        'aria-label',
        currentTheme() === 'dark' ? 'Activar modo claro' : 'Activar modo oscuro'
      );
    }
  }
  function setTheme(theme: string) {
    if (theme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    } else {
      document.documentElement.removeAttribute('data-theme');
    }
    try { localStorage.setItem('theme', theme); } catch {}
    syncThemeUI();
    updateNavbar();
    updateLogo();
  }
  syncThemeUI();
  themeToggle?.addEventListener('click', () => {
    setTheme(currentTheme() === 'dark' ? 'light' : 'dark');
  });
</script>

<style>
  /* --- Top bar actions --- */
  .navbar-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .navbar-actions { gap: 1rem; }
  }

  /* --- Theme toggle (top bar, icon only, theme-aware) --- */
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--border-subtle);
    color: var(--cream);
    cursor: pointer;
    transition: color 0.3s, border-color 0.3s, background 0.3s;
    -webkit-tap-highlight-color: transparent;
  }
  .theme-toggle:hover {
    color: var(--plum);
    border-color: var(--plum);
  }
  .theme-icon { flex-shrink: 0; }
  /* Light mode → show moon (offer dark). Dark mode → show sun (offer light). */
  .theme-icon-sun { display: none; }
  .theme-icon-moon { display: block; }
  :global(:root[data-theme="dark"]) .theme-icon-sun { display: block; }
  :global(:root[data-theme="dark"]) .theme-icon-moon { display: none; }
  /* While the fullscreen menu is open, force white over the navy overlay */
  :global(body.menu-open) .theme-toggle {
    color: #FFFFFF;
    border-color: rgba(255, 255, 255, 0.3);
  }
  :global(body.menu-open) .theme-toggle:hover {
    color: var(--lilac);
    border-color: var(--lilac);
  }

  /* --- Menu toggle --- */
  .menu-toggle {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.5rem 0;
    position: relative;
    z-index: 80;
    -webkit-tap-highlight-color: transparent;
  }
  .menu-toggle-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--cream);
    transition: color 0.3s;
  }
  .hamburger-line {
    width: 100%;
    height: 2px;
    background: var(--cream);
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: center;
  }
  #hamburger.open .hamburger-line { background: #FFFFFF; }
  #hamburger.open .hamburger-line:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  #hamburger.open .hamburger-line:nth-child(2) { opacity: 0; }
  #hamburger.open .hamburger-line:nth-child(3) { transform: rotate(-45deg) translate(6px, -6px); }
  .menu-toggle[aria-expanded="true"] .menu-toggle-label { color: #FFFFFF; }

  /* --- Fullscreen menu --- */
  .fs-menu {
    position: fixed;
    inset: 0;
    z-index: 65;
    background: #0A1F4A;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow-y: auto;
    padding: 6.5rem 1.5rem 2.5rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), visibility 0s linear 0.5s;
  }
  @media (min-width: 768px) {
    .fs-menu { padding: 7.5rem 4rem 3rem; }
  }
  .fs-menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), visibility 0s;
  }

  .fs-menu-nav {
    display: flex;
    flex-direction: column;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  .fs-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.75rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #FFFFFF;
    text-decoration: none;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    transition: color 0.3s, padding-left 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    /* entrance animation */
    opacity: 0;
    transform: translateY(28px);
  }
  .fs-menu.is-open .fs-link {
    opacity: 1;
    transform: translateY(0);
    transition: color 0.3s, padding-left 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .fs-menu.is-open .fs-link:nth-child(1) { transition-delay: 0.08s, 0.08s, 0.08s, 0.08s; }
  .fs-menu.is-open .fs-link:nth-child(2) { transition-delay: 0.14s, 0.14s, 0.14s, 0.14s; }
  .fs-menu.is-open .fs-link:nth-child(3) { transition-delay: 0.20s, 0.20s, 0.20s, 0.20s; }
  .fs-menu.is-open .fs-link:nth-child(4) { transition-delay: 0.26s, 0.26s, 0.26s, 0.26s; }
  .fs-menu.is-open .fs-link:nth-child(5) { transition-delay: 0.32s, 0.32s, 0.32s, 0.32s; }
  .fs-menu.is-open .fs-link:nth-child(6) { transition-delay: 0.38s, 0.38s, 0.38s, 0.38s; }
  .fs-menu.is-open .fs-link:nth-child(7) { transition-delay: 0.44s, 0.44s, 0.44s, 0.44s; }

  .fs-link:hover {
    color: var(--lilac);
    padding-left: 1.25rem;
  }

  .fs-menu-footer {
    max-width: 1440px;
    margin: auto auto 0;
    padding-top: 2.5rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  @media (min-width: 768px) {
    .fs-menu-footer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
  .fs-menu.is-open .fs-menu-footer {
    opacity: 1;
    transition: opacity 0.6s ease 0.5s;
  }

  .fs-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: #0A1F4A;
    background: var(--lilac);
    padding: 0.85rem 1.75rem;
    border-radius: 999px;
    text-decoration: none;
    width: fit-content;
    transition: transform 0.3s, background 0.3s;
  }
  .fs-cta:hover { transform: translateY(-2px); background: #FFFFFF; }

  .fs-menu-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.55);
  }
  .fs-menu-meta a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.3s;
  }
  .fs-menu-meta a:hover { color: var(--lilac); }

  @media (prefers-reduced-motion: reduce) {
    .fs-link { opacity: 1; transform: none; }
    .fs-menu, .fs-link, .fs-menu-footer { transition: opacity 0.2s ease; }
  }
</style>
