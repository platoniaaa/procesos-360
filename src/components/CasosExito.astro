---
const casos = [
  {
    cliente: 'SONAMI',
    sector: 'Industria minera · Asociación gremial',
    logo: '/img/clients/sonami.png',
    titulo: 'Modernización de la SONAMI',
    descripcion: 'Modernización de la organización para contar con una estructura organizacional ágil y transparente, con un liderazgo basado en competencias y mayor satisfacción laboral interna.',
    contacto: 'Richard Araya, Gerente General',
    servicios: [
      'Análisis y diseño de procesos',
      'Implementación de metodologías',
      'Capacitación y desarrollo',
      'Gestión del Cambio',
      'Soporte Continuo',
    ],
  },
  {
    cliente: 'Copec',
    sector: 'Energía · Sector Combustible',
    logo: '/img/clients/copec.png',
    titulo: 'Arquitectura de Procesos — Sector Combustible',
    descripcion: 'Diseñar una arquitectura de procesos de las operaciones del Sector Combustible de Copec que permita mejorar el proceso de Auditoría de manera más ágil y efectiva, proyectando la conformación de un Gobierno por Procesos en Copec.',
    contacto: null,
    servicios: [
      'Análisis y diseño de procesos',
      'Implementación de metodologías',
      'Gestión del Cambio',
    ],
  },
];
---

<section id="casos" class="relative py-20 md:py-32 overflow-hidden" style="background:var(--night);">

  <!-- Subtle ambient glow -->
  <div class="orb w-[450px] h-[450px] top-[10%] left-[-12%]" style="background:radial-gradient(circle, rgba(30,91,255,0.16) 0%, transparent 60%);"></div>
  <div class="orb w-[400px] h-[400px] bottom-[5%] right-[-12%]" style="background:radial-gradient(circle, rgba(41,201,214,0.14) 0%, transparent 60%);animation-delay:-2s;"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Header -->
    <div class="grid grid-cols-12 gap-4 md:gap-8 mb-14 md:mb-20 fade-up">
      <div class="col-span-12 md:col-span-3">
        <div class="eyebrow eyebrow-dot mb-4">Casos de &eacute;xito</div>
        <div class="hairline w-16"></div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg">
          Fomentamos una cultura
          <br/>
          de <span class="italic-accent">mejora continua</span>.
        </h2>
        <p class="mt-5 text-base md:text-lg max-w-2xl leading-relaxed" style="color:var(--text-muted);">
          Algunos de los proyectos donde hemos acompañado a empresas líderes en la transformación de sus procesos.
        </p>
      </div>
    </div>

    <!-- Cases grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 md:gap-6">
      {casos.map((caso, i) => (
        <article class="fade-up violet-card caso-card" style={`transition-delay: ${i * 120}ms;padding:2rem;`}>

          <!-- Header: logo + cliente -->
          <div class="caso-head">
            <div class="caso-logo-wrap">
              <img src={caso.logo} alt={caso.cliente} class="caso-logo" loading="lazy" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="caso-cliente">{caso.cliente}</div>
              <div class="caso-sector">{caso.sector}</div>
            </div>
          </div>

          <!-- Titulo + descripcion -->
          <h3 class="caso-titulo">{caso.titulo}</h3>
          <p class="caso-desc">{caso.descripcion}</p>

          {caso.contacto && (
            <div class="caso-contacto">
              <span class="marginalia" style="color:var(--text-muted);">Contraparte</span>
              <span>{caso.contacto}</span>
            </div>
          )}

          <!-- Servicios aplicados -->
          <div class="caso-servicios">
            <div class="marginalia mb-3" style="color:var(--text-muted);">Servicios aplicados</div>
            <div class="caso-tags">
              {caso.servicios.map(s => (
                <span class="caso-tag">{s}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .caso-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .caso-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(30, 91, 255, 0.10);
  }

  .caso-logo-wrap {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    background: #FFFFFF;
    border-radius: 12px;
    border: 1px solid rgba(30, 91, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
  }

  .caso-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .caso-cliente {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--cream);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .caso-sector {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--plum);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 4px;
  }

  .caso-titulo {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    color: var(--cream);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .caso-desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0;
  }

  .caso-contacto {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 0.75rem;
    font-size: 0.88rem;
    color: var(--cream);
  }

  .caso-servicios {
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(30, 91, 255, 0.10);
  }

  .caso-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .caso-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(30, 91, 255, 0.08);
    border: 1px solid rgba(30, 91, 255, 0.18);
    color: var(--plum);
    letter-spacing: 0.02em;
  }
</style>
