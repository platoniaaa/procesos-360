---
import logoCompleto from '../assets/img/logo-completo.png';

const links = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Productos', href: '#productos' },
  { label: 'Asistente IA', href: '#asistente' },
  { label: '¿Por qué Procesos 360?', href: '#por-que-procesos360' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];

const year = new Date().getFullYear();
---

<footer class="relative pt-20 md:pt-28 pb-10 overflow-hidden" style="background:var(--void);">
  <div class="absolute inset-0 noise-bg"></div>
  <div class="orb w-[600px] h-[600px] top-[-20%] left-[-15%]" style="background:radial-gradient(circle, rgba(41,201,214,0.15) 0%, transparent 60%);"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Huge display headline -->
    <div class="mb-20 md:mb-28 fade-up">
      <div class="eyebrow mb-6" style="color:var(--gold);">
        <span class="eyebrow-dot">Ep&iacute;logo</span>
      </div>
      <h3 class="display-xl" style="font-size:clamp(2.5rem,10vw,8rem);line-height:0.92;">
        La sabidur&iacute;a de
        <span class="italic-accent">hacer las cosas bien,</span>
        <br/>
        con la inteligencia de
        <span class="italic-accent">hacerlas mejor.</span>
      </h3>
    </div>

    <!-- Grid info -->
    <div class="grid grid-cols-12 gap-8 md:gap-10 mb-16 pb-14 border-b" style="border-color:rgba(30,91,255,0.1);">

      <div class="col-span-12 md:col-span-5">
        <img src={logoCompleto.src} alt="Procesos 360" class="h-9 w-auto mb-6" />
        <p class="text-base leading-relaxed max-w-sm" style="color:var(--text-muted);">
          Startup tecnol&oacute;gica chilena especializada en soluciones digitales inteligentes para pymes: presencia digital, automatizaci&oacute;n con IA, sistemas de gesti&oacute;n y desarrollo a medida.
        </p>
      </div>

      <div class="col-span-6 md:col-span-3">
        <div class="eyebrow mb-5">&Iacute;ndice</div>
        <ul class="space-y-2.5">
          {links.map(link => (
            <li>
              <a href={link.href} class="text-sm transition-all hover:text-white" style="color:var(--text-muted);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-6 md:col-span-4">
        <div class="eyebrow mb-5">Contacto</div>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="mailto:javier.espinoza@procesos360.cl" class="link-underline">javier.espinoza@procesos360.cl</a>
          </li>
          <li>
            <a href="https://wa.me/56964261751" target="_blank" rel="noopener noreferrer" class="link-underline">+569 64261751</a>
          </li>
          <li style="color:var(--text-muted);">Santiago, Chile</li>
        </ul>

        <div class="flex gap-3 mt-8">
          <a href="https://www.instagram.com/procesos360.cl/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 rounded-full flex items-center justify-center transition-all" style="border:1px solid rgba(30,91,255,0.2);color:var(--lilac);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/procesos360/posts/?feedView=all" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-10 h-10 rounded-full flex items-center justify-center transition-all" style="border:1px solid rgba(30,91,255,0.2);color:var(--lilac);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://wa.me/56964261751" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-10 h-10 rounded-full flex items-center justify-center transition-all" style="border:1px solid rgba(30,91,255,0.2);color:var(--lilac);">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <div class="marginalia">
        &copy; {year} Procesos 360 &mdash; Todos los derechos reservados
      </div>
      <div class="marginalia">
        Est. MMXXVI &bull; Santiago &mdash; Chile
      </div>
    </div>
  </div>
</footer>
