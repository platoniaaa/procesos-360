---
const team = [
  {
    photo: '/img/team/javier-espinoza.jpg',
    name: 'Javier Espinoza Covarrubias',
    role: 'Socio Director',
    bio: 'MBA de la Universidad de Chile e Ingeniero Civil Industrial USACH, con más de 23 años liderando proyectos de mejora continua en minería, energía, retail, banca y sector público.',
    ring: 'var(--plum)',
  },
  {
    photo: '/img/team/ignacio-calderon.jpg',
    name: 'Ignacio Calderón',
    role: 'Ingeniero de Procesos y Automatización',
    bio: 'Ingeniero Civil Industrial USACH con formación en Ciencia de Datos. Especialista en IA aplicada a la optimización de procesos y automatización comercial.',
    ring: 'var(--lilac)',
  },
  {
    photo: '/img/team/francisco-guajardo.jpg',
    name: 'Francisco Guajardo',
    role: 'Analista de Procesos y Analítica de Datos',
    bio: 'Ingeniería Civil Industrial USACH con Ciencia de Datos Avanzado y Diplomado en Inteligencia de Negocios PUC. Experiencia en analítica con Python, Power BI y SQL.',
    ring: 'var(--gold)',
  },
];
---

<section id="equipo" class="team-section">
  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Header (centered, Olivia-style) -->
    <div class="team-header fade-up">
      <div class="eyebrow eyebrow-dot team-eyebrow">Nuestro equipo</div>
      <h2 class="team-title">
        Las personas detrás de cada
        <span class="team-title-accent">transformación</span>.
      </h2>
    </div>

    <!-- Team grid -->
    <div class="team-grid">
      {team.map((person, i) => (
        <article class="team-member fade-up" style={`transition-delay: ${i * 120}ms;`}>
          <div class="team-photo-ring" style={`--ring-color: ${person.ring};`} data-parallax={i % 2 === 0 ? '0.07' : '0.14'}>
            <svg class="team-arc" viewBox="0 0 100 100" aria-hidden="true">
              <circle cx="50" cy="50" r="47" fill="none" stroke="var(--ring-color)" stroke-width="3.5" stroke-linecap="round" stroke-dasharray="218 295" transform="rotate(-100 50 50)" />
            </svg>
            <div class="team-photo">
              <img src={person.photo} alt={person.name} loading="lazy" />
            </div>
          </div>
          <h3 class="team-name">{person.name}</h3>
          <div class="team-role">{person.role}</div>
          <p class="team-bio">{person.bio}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team-section {
    position: relative;
    overflow: hidden;
    padding: 5rem 0;
    background: #0A1F4A;
  }
  @media (min-width: 768px) {
    .team-section { padding: 7rem 0 8rem; }
  }

  .team-header {
    text-align: center;
    max-width: 900px;
    margin: 0 auto 4rem;
  }
  @media (min-width: 768px) {
    .team-header { margin-bottom: 5.5rem; }
  }
  .team-eyebrow {
    color: var(--lilac);
    display: inline-block;
    margin-bottom: 1.25rem;
  }
  .team-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: #FFFFFF;
  }
  .team-title-accent {
    color: var(--lilac);
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .team-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .team-member {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* --- Circular photo with arc --- */
  .team-photo-ring {
    position: relative;
    width: 220px;
    height: 220px;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 1024px) {
    .team-photo-ring { width: 240px; height: 240px; }
  }

  .team-arc {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .team-member:hover .team-arc {
    transform: rotate(120deg);
  }

  .team-photo {
    position: absolute;
    inset: 14px;
    border-radius: 50%;
    overflow: hidden;
    background: #F5F8FD;
  }
  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .team-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
    color: #FFFFFF;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 4px;
  }

  .team-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--lilac);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  .team-bio {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    max-width: 320px;
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .team-arc { transition: none; }
    .team-member:hover .team-arc { transform: none; }
  }
</style>
