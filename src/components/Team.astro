---
const team = [
  {
    photo: '/img/team/javier-espinoza.jpg',
    name: 'Javier Espinoza Covarrubias',
    role: 'Socio Director',
    bio: 'MBA de la Universidad de Chile e Ingeniero Civil Industrial USACH, con más de 23 años de experiencia liderando implementaciones funcionales de plataformas TI y proyectos de mejora continua en minería, energía, retail, banca, transporte y sector público.',
    tags: ['Design Thinking', 'Customer Experience', 'End-to-End'],
  },
  {
    photo: '/img/team/ignacio-calderon.jpg',
    name: 'Ignacio Calderón',
    role: 'Ingeniero de Procesos y Automatización',
    bio: 'Ingeniero Civil Industrial USACH con formación complementaria en Ciencia de Datos. Especialista en inteligencia artificial aplicada a la optimización de procesos, automatización de operaciones comerciales y desarrollo de soluciones basadas en datos.',
    tags: ['IA aplicada', 'Automatización', 'Ciencia de Datos'],
  },
  {
    photo: '/img/team/francisco-guajardo.jpg',
    name: 'Francisco Guajardo',
    role: 'Analista de Procesos y Analítica de Datos',
    bio: 'Estudiante de Ingeniería Civil Industrial USACH con Ciencia de Datos Avanzado y Diplomado en Inteligencia de Negocios de la PUC. Experiencia en reingeniería de procesos y analítica avanzada con Python, Power BI y SQL en sector financiero y servicios.',
    tags: ['Power BI', 'Python · SQL', 'Inteligencia de Negocios'],
  },
];
---

<section id="equipo" class="relative py-20 md:py-32 overflow-hidden" style="background:var(--night);">

  <!-- Ambient glow -->
  <div class="orb w-[500px] h-[500px] top-[5%] right-[-15%]" style="background:radial-gradient(circle, rgba(30,91,255,0.16) 0%, transparent 60%);"></div>
  <div class="orb w-[400px] h-[400px] bottom-[10%] left-[-12%]" style="background:radial-gradient(circle, rgba(41,201,214,0.14) 0%, transparent 60%);animation-delay:-3s;"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Header -->
    <div class="grid grid-cols-12 gap-4 md:gap-8 mb-14 md:mb-20 fade-up">
      <div class="col-span-12 md:col-span-3">
        <div class="eyebrow eyebrow-dot mb-4">Nuestro equipo</div>
        <div class="hairline w-16"></div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg">
          Profesionales detrás
          <br/>
          de cada <span class="italic-accent">transformación</span>.
        </h2>
        <p class="mt-5 text-base md:text-lg max-w-2xl leading-relaxed" style="color:var(--text-muted);">
          Combinamos experiencia en consultoría, conocimiento técnico y habilidades interpersonales para enfrentar cualquier desafío y entregar soluciones efectivas a nuestros clientes.
        </p>
      </div>
    </div>

    <!-- Team grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {team.map((person, i) => (
        <article class="fade-up violet-card team-card" style={`transition-delay: ${i * 100}ms;padding:0;overflow:hidden;`}>

          <!-- Photo -->
          <div class="team-photo-wrap">
            <img src={person.photo} alt={person.name} class="team-photo" loading="lazy" />
          </div>

          <!-- Body -->
          <div class="team-body">
            <h3 class="team-name">{person.name}</h3>
            <div class="team-role">{person.role}</div>
            <p class="team-bio">{person.bio}</p>

            <!-- Tags -->
            <div class="team-tags">
              {person.tags.map(t => (
                <span class="team-tag">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team-card {
    display: flex;
    flex-direction: column;
  }

  .team-photo-wrap {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: linear-gradient(180deg, #F5F8FD 0%, #EAF1FB 100%);
    overflow: hidden;
    position: relative;
  }

  .team-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 22%;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .team-card:hover .team-photo {
    transform: scale(1.04);
  }

  .team-body {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  @media (min-width: 768px) {
    .team-body {
      padding: 1.75rem 1.75rem 2rem;
    }
  }

  .team-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--cream);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 4px;
  }

  .team-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--plum);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  .team-bio {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0 0 1.25rem;
    flex: 1;
  }

  .team-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(30, 91, 255, 0.10);
  }

  .team-tag {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(41, 201, 214, 0.10);
    border: 1px solid rgba(41, 201, 214, 0.25);
    color: var(--plum);
    letter-spacing: 0.02em;
  }
</style>
