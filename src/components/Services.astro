---
const services = [
  {
    title: 'Mejoramiento de Procesos',
    description: 'Levantamos AS-IS y rediseñamos TO-BE con BPMN, SIPOC y RACI. Una metodología propia de 5 fases, respaldada por nuestra alianza como partners de SAP Signavio y SAP LeanIX.',
  },
  {
    title: 'Ingeniería Cognitiva de Procesos Adaptativos',
    description: 'Capturamos el conocimiento tácito de tus expertos —cómo deciden, cuándo aplican excepciones— y lo convertimos en un modelo formal reutilizable y escalable.',
  },
  {
    title: 'Gobierno de IA',
    description: 'Frameworks de gobernanza responsables y éticos para implementar IA alineada con tu estrategia corporativa: políticas, roles, comités y gestión de riesgos algorítmicos.',
  },
  {
    title: 'Transformación Empresarial con IA',
    description: 'Rediseño de procesos primero, automatización e IA después. Combinamos gestión por procesos, RPA y analítica avanzada para que la IA sea un activo real, no un proyecto aislado.',
  },
  {
    title: 'Gestión del Cambio',
    description: 'Acompañamos a personas y equipos para que los nuevos procesos no se queden en el papel: comunicación, capacitación, coaching de líderes y monitoreo de adopción.',
  },
  {
    title: 'Soporte Continuo',
    description: 'Mejora continua post go-live: monitoreo de KPIs operativos, ajustes incrementales y optimización iterativa para sostener los resultados en el tiempo.',
  },
];
---

<section id="servicios" class="relative py-20 md:py-32 overflow-hidden" style="background:var(--night);">
  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <div class="grid grid-cols-12 gap-8 md:gap-12 lg:gap-20">

      <!-- LEFT — headline + dynamic description -->
      <div class="col-span-12 lg:col-span-5 fade-up">
        <div class="eyebrow eyebrow-dot mb-5">Servicios</div>
        <h2 class="display-md mb-8" style="font-size:clamp(1.9rem,4vw,3rem);">
          Transformando tus procesos en tus <span class="italic-accent">activos estrat&eacute;gicos</span>.
        </h2>

        <p id="svc-desc" class="svc-desc">
          Levantamos AS-IS y redise&ntilde;amos TO-BE con BPMN, SIPOC y RACI. Una metodolog&iacute;a propia de 5 fases, respaldada por nuestra alianza como partners de SAP Signavio y SAP LeanIX.
        </p>

        <a href="#contacto" class="svc-cta">
          Conversemos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <!-- RIGHT — interactive service list -->
      <div class="col-span-12 lg:col-span-7 fade-up" style="transition-delay:120ms;">
        <div class="svc-list">
          {services.map((s, i) => (
            <button
              type="button"
              class:list={['svc-item', { 'is-active': i === 0 }]}
              data-index={i}
              data-desc={s.description}
            >
              {s.title}
            </button>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>('.svc-item');
  const descEl = document.getElementById('svc-desc');
  let activeIndex = 0;

  function setActive(item: HTMLButtonElement) {
    const idx = Number(item.dataset.index);
    if (idx === activeIndex) return;
    activeIndex = idx;

    items.forEach((el) => el.classList.toggle('is-active', el === item));

    if (descEl) {
      descEl.classList.add('is-swapping');
      window.setTimeout(() => {
        descEl.textContent = item.dataset.desc || '';
        descEl.classList.remove('is-swapping');
      }, 160);
    }
  }

  items.forEach((item) => {
    item.addEventListener('mouseenter', () => setActive(item));
    item.addEventListener('click', () => setActive(item));
    item.addEventListener('focus', () => setActive(item));
  });
</script>

<style>
  .svc-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 2rem;
    min-height: 8.5rem;
    transition: opacity 0.16s ease;
  }
  .svc-desc.is-swapping { opacity: 0; }

  .svc-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--plum);
    text-decoration: none;
    transition: gap 0.3s;
  }
  .svc-cta:hover { gap: 0.85rem; }

  /* --- Right list — clean, Olivia-style --- */
  .svc-list {
    display: flex;
    flex-direction: column;
  }
  .svc-item {
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(30, 91, 255, 0.16);
    padding: 0.85rem 0;
    cursor: pointer;
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.25rem, 2.8vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    transition: color 0.25s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .svc-item:first-child { border-top: 1px solid rgba(30, 91, 255, 0.16); }
  @media (min-width: 768px) {
    .svc-item { padding: 1.05rem 0; }
  }

  .svc-item:hover,
  .svc-item.is-active {
    color: var(--plum);
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-item, .svc-desc, .svc-cta { transition: none; }
  }
</style>
