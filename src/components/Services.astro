---
const services = [
  {
    num: '01',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Presencia Digital',
    tag: 'para que te encuentren',
    description: 'Sitios web, landing pages y tiendas online optimizadas para Google y diseñadas para generar confianza.',
  },
  {
    num: '02',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: 'Automatización Inteligente',
    tag: 'para recuperar tiempo',
    description: 'Automatizamos procesos con IA: facturación, atención al cliente por WhatsApp, reportes y más.',
  },
  {
    num: '03',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
    title: 'Gestión de Negocio',
    tag: 'para ver todo claro',
    description: 'ERP y CRM que centralizan ventas, inventario, finanzas y clientes. Adiós planillas de Excel.',
  },
  {
    num: '04',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>`,
    title: 'Integración de Sistemas',
    tag: 'para que hablen entre sí',
    description: 'Conectamos tus herramientas para que la información fluya sin intervención manual.',
  },
  {
    num: '05',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="12" y1="2" x2="12" y2="22"/></svg>`,
    title: 'Desarrollo a Medida',
    tag: 'para lo que no existe',
    description: 'Cuando ninguna solución estándar encaja, la construimos. Plataformas, apps, dashboards.',
  },
];
---

<section id="servicios" class="relative py-20 md:py-32 overflow-hidden" style="background:var(--night);">

  <!-- Ambient glows -->
  <div class="orb w-[400px] h-[400px] top-[-5%] left-[-10%]" style="background:radial-gradient(circle, rgba(41,201,214,0.15) 0%, transparent 65%);"></div>
  <div class="orb w-[350px] h-[350px] bottom-[5%] right-[-10%]" style="background:radial-gradient(circle, rgba(30,91,255,0.18) 0%, transparent 65%);animation-delay:-3s;"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Header -->
    <div class="grid grid-cols-12 gap-4 md:gap-8 mb-16 md:mb-24 fade-up">
      <div class="col-span-12 md:col-span-3">
        <div class="eyebrow eyebrow-dot mb-4">Secci&oacute;n I</div>
        <div class="hairline w-16"></div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg">
          No vendemos tecnolog&iacute;a.
          <br/>
          <span class="italic-accent">Resolvemos</span> problemas.
        </h2>
      </div>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {services.map((service, i) => (
        <div class="fade-up violet-card group" style={`transition-delay: ${i * 100}ms`}>

          <div class="flex items-start justify-between mb-8">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-colors duration-500" style="background:rgba(41,201,214,0.12);color:var(--lilac);border:1px solid rgba(41,201,214,0.2);">
              <Fragment set:html={service.icon} />
            </div>
            <span class="font-mono-accent text-xs" style="color:var(--text-muted);">
              /{service.num}
            </span>
          </div>

          <h3 class="display-md mb-2">
            {service.title}
          </h3>
          <p class="italic-accent text-base mb-5" style="font-size:1rem;">
            &mdash; {service.tag}
          </p>

          <p class="text-base leading-relaxed mb-6" style="color:var(--text-muted);">
            {service.description}
          </p>

          <a href="#contacto" class="inline-flex items-center gap-2 text-sm link-underline" style="color:var(--lilac);">
            <span>Conversemos</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
