---
const steps = [
  { num: '01', title: 'Escuchar', desc: 'Nos reunimos contigo para entender tu negocio, tus desafíos y tus objetivos.' },
  { num: '02', title: 'Diseñar', desc: 'Proponemos una solución a medida con alcance claro y presupuesto transparente.' },
  { num: '03', title: 'Construir', desc: 'Desarrollamos con metodologías ágiles, mostrándote avances constantes.' },
  { num: '04', title: 'Acompañar', desc: 'Entregamos, capacitamos a tu equipo y ofrecemos soporte continuo.' },
];
---

<section id="por-que-procesos360" class="relative py-20 md:py-32 overflow-hidden" style="background:var(--night);">

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <!-- Process -->
    <div class="fade-up">
      <div class="grid grid-cols-12 gap-4 md:gap-8 mb-12 md:mb-16">
        <div class="col-span-12 md:col-span-3">
          <div class="eyebrow eyebrow-dot mb-4">Proceso</div>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h3 class="display-md">
            C&oacute;mo <span class="italic-accent">trabajamos.</span>
          </h3>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-5">
        {steps.map((step, i) => (
          <div class="fade-up violet-card relative" style={`transition-delay: ${i * 100}ms;padding:1.75rem;`} data-parallax={i % 2 === 0 ? '0.05' : '0.11'}>
            <span class="chapter-num block mb-4" style="font-size:3rem;line-height:1;">
              {step.num}
            </span>
            <h4 class="display-md mb-3" style="font-size:1.4rem;">
              {step.title}
            </h4>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted);">
              {step.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
