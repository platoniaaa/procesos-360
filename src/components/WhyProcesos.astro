---
const reasons = [
  { n: '01', title: 'Comprensión del negocio', desc: 'Poseemos un profundo entendimiento del negocio de nuestros clientes, incluyendo sus objetivos estratégicos, estructura organizativa, cultura empresarial y desafíos específicos.' },
  { n: '02', title: 'Experiencia en gestión por procesos', desc: 'Contamos con experiencia y conocimientos sólidos en metodologías de gestión por procesos, como Lean Management y BPM (Business Process Management), entre otras, para ofrecer soluciones efectivas y personalizadas.' },
  { n: '03', title: 'Enfoque centrado en el cliente', desc: 'Ponemos al cliente en el centro de nuestras acciones y desarrollamos soluciones alineadas con sus necesidades y objetivos empresariales.' },
  { n: '04', title: 'Tecnología y herramientas adecuadas', desc: 'Estamos al tanto de las últimas tendencias tecnológicas y herramientas para la optimización de procesos, recomendando e implementando aquellas que mejor se adapten a las necesidades de cada cliente.' },
  { n: '05', title: 'Desarrollo del talento humano', desc: 'Reconocemos la importancia del factor humano en la gestión por procesos: promovemos el desarrollo profesional de los colaboradores, ofreciendo capacitación y apoyo para mejorar sus habilidades y competencias.' },
  { n: '06', title: 'Enfoque en la mejora continua', desc: 'Adoptamos una mentalidad de mejora continua, trabajando en colaboración con nuestros clientes para identificar oportunidades de optimización y desarrollar soluciones que impulsen la eficiencia y la innovación.' },
];

const steps = [
  { num: '01', title: 'Escuchar', desc: 'Nos reunimos contigo para entender tu negocio, tus desafíos y tus objetivos.' },
  { num: '02', title: 'Diseñar', desc: 'Proponemos una solución a medida con alcance claro y presupuesto transparente.' },
  { num: '03', title: 'Construir', desc: 'Desarrollamos con metodologías ágiles, mostrándote avances constantes.' },
  { num: '04', title: 'Acompañar', desc: 'Entregamos, capacitamos a tu equipo y ofrecemos soporte continuo.' },
];
---

<section id="por-que-procesos360" class="relative py-20 md:py-32 overflow-hidden" style="background:var(--night);">

  <div class="orb w-[400px] h-[400px] top-[10%] left-[-10%]" style="background:radial-gradient(circle, rgba(30,91,255,0.18) 0%, transparent 60%);"></div>
  <div class="orb w-[350px] h-[350px] bottom-[20%] right-[-10%]" style="background:radial-gradient(circle, rgba(41,201,214,0.15) 0%, transparent 60%);animation-delay:-4s;"></div>

  <div class="absolute inset-0 dot-grid-bg opacity-40"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-10">

    <div class="grid grid-cols-12 gap-4 md:gap-8 mb-16 md:mb-24 fade-up">
      <div class="col-span-12 md:col-span-3">
        <div class="eyebrow eyebrow-dot mb-4">Secci&oacute;n III</div>
        <div class="hairline w-16"></div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg">
          Seis razones
          <span class="italic-accent">por las que</span>
          <br/>elegirnos.
        </h2>
      </div>
    </div>

    <!-- Reasons list -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-y-10 md:gap-y-14 gap-x-12 md:gap-x-20 mb-28 md:mb-36">
      {reasons.map((reason, i) => (
        <div class="fade-up flex gap-6 md:gap-8" style={`transition-delay: ${i * 80}ms`}>
          <span class="font-mono-accent text-xs uppercase tracking-[0.2em] pt-1 flex-shrink-0 w-10" style="color:var(--lilac);">
            {reason.n}
          </span>
          <div class="flex-1">
            <h4 class="display-md mb-3" style="font-size:clamp(1.4rem,2.8vw,1.9rem);line-height:1.15;">
              {reason.title}
            </h4>
            <p class="text-base leading-relaxed" style="color:var(--text-muted);">
              {reason.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Process -->
    <div class="fade-up">
      <div class="grid grid-cols-12 gap-4 md:gap-8 mb-12 md:mb-16">
        <div class="col-span-12 md:col-span-3">
          <div class="eyebrow eyebrow-dot mb-4">Proceso</div>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h3 class="display-md">
            C&oacute;mo <span class="italic-accent">trabajamos.</span>
          </h3>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-5">
        {steps.map((step, i) => (
          <div class="fade-up violet-card relative" style={`transition-delay: ${i * 100}ms;padding:1.75rem;`}>
            <span class="chapter-num block mb-4" style="font-size:3rem;line-height:1;">
              {step.num}
            </span>
            <h4 class="display-md mb-3" style="font-size:1.4rem;">
              {step.title}
            </h4>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted);">
              {step.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
