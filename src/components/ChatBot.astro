---
import isotipo from '../assets/img/isotipo.png';
---

<section id="asistente" class="relative py-12 md:py-28 overflow-hidden" style="background:var(--midnight);">

  <div class="orb w-[500px] h-[500px] top-[10%] right-[-10%]" style="background:radial-gradient(circle, rgba(41,201,214,0.25) 0%, transparent 60%);"></div>
  <div class="orb w-[400px] h-[400px] bottom-[10%] left-[-15%]" style="background:radial-gradient(circle, rgba(229,66,181,0.12) 0%, transparent 65%);animation-delay:-2s;"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-4 sm:px-6 md:px-10">

    <div class="grid grid-cols-12 gap-4 md:gap-8 mb-8 md:mb-14 fade-up">
      <div class="col-span-12 md:col-span-3">
        <div class="eyebrow eyebrow-dot mb-3" style="color:var(--gold);">Di&aacute;logo</div>
        <div class="hairline w-16 hidden md:block"></div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg" style="font-size:clamp(1.75rem, 5.5vw, 4.5rem);">
          &iquest;No sabes qu&eacute; necesitas?
          <br/>
          <span class="italic-accent">Preg&uacute;ntale</span> a nuestra IA.
        </h2>
        <p class="mt-4 md:mt-6 max-w-xl text-sm md:text-lg leading-relaxed" style="color:var(--text-muted);">
          Cu&eacute;ntale tu desaf&iacute;o al asistente digital de Procesos 360 y recibe un diagn&oacute;stico personalizado.
        </p>
      </div>
    </div>

    <div class="fade-up max-w-[820px] mx-auto">
      <div id="chat-placeholder" class="chat-placeholder" style="display:none;"></div>
      <div id="chat-container" class="chat-box">
        <div class="chat-header">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center rounded-full" style="background:linear-gradient(135deg, var(--lilac), var(--plum));">
              <img src={isotipo.src} alt="Procesos 360" style="width:22px;height:22px;object-fit:contain;filter:brightness(0) invert(1);" />
            </div>
            <div>
              <div class="text-sm font-semibold" style="color:var(--cream);font-family:var(--font-display);">
                Asistente <span class="italic-accent" style="font-weight:500;">Procesos 360</span>
              </div>
              <div class="flex items-center gap-1.5 mt-0.5">
                <span class="w-1.5 h-1.5 rounded-full" style="background:#22c55e;animation:pulse-whatsapp 2s ease-in-out infinite;"></span>
                <span class="marginalia" style="font-size:0.65rem;">En l&iacute;nea</span>
              </div>
            </div>
          </div>
          <div class="chat-header-right">
            <span class="hidden md:block marginalia chat-header-caption">Captura I &mdash;</span>
            <button id="chat-expand" class="chat-expand-btn" aria-label="Pantalla completa" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
            </button>
            <button id="chat-close" class="chat-close-btn" aria-label="Cerrar pantalla completa" type="button" style="display:none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        </div>

        <div id="chat-messages" class="chat-messages"></div>

        <div id="chat-typing" class="chat-typing" style="display:none;">
          <div class="typing-bubble">
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
          </div>
        </div>

        <div class="chat-input-area">
          <div class="chat-input-wrapper">
            <textarea id="chat-input" class="chat-input" placeholder="Escribe tu mensaje..." rows="1" maxlength="500"></textarea>
            <span id="char-count" class="char-count" style="display:none;">500</span>
            <button id="chat-send" class="chat-send" aria-label="Enviar mensaje">
              <svg id="send-icon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              <svg id="send-spinner" class="w-4 h-4 animate-spin" style="display:none;" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </div>
        </div>

        <div id="chat-limit" class="chat-limit" style="display:none;">
          <p>Para continuar la conversaci&oacute;n, d&eacute;janos tus datos y te contactamos personalmente.</p>
          <a href="#contacto" class="btn-primary !py-2.5 !px-6 !text-sm mt-5 touch-manipulation">Ir al formulario</a>
        </div>
      </div>

      <div class="flex justify-between mt-5 marginalia">
        <span>Fig. 02 &mdash; Interfaz conversacional</span>
        <span>&darr; Escribe o usa sugerencias</span>
      </div>
    </div>
  </div>
</section>

<script>
  const messagesEl = document.getElementById('chat-messages')!;
  const inputEl = document.getElementById('chat-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
  const sendIcon = document.getElementById('send-icon')!;
  const sendSpinner = document.getElementById('send-spinner')!;
  const typingEl = document.getElementById('chat-typing')!;
  const charCount = document.getElementById('char-count')!;
  const limitEl = document.getElementById('chat-limit')!;
  const chatContainer = document.getElementById('chat-container')!;
  const chatPlaceholder = document.getElementById('chat-placeholder')!;
  const expandBtn = document.getElementById('chat-expand')!;
  const closeBtn = document.getElementById('chat-close')!;

  let isFullscreen = false;
  let originalParent: HTMLElement | null = null;
  let originalNextSibling: ChildNode | null = null;
  let savedScrollY = 0;

  function openFullscreen() {
    if (isFullscreen) return;
    isFullscreen = true;

    // Save current scroll position BEFORE doing anything else
    savedScrollY = window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0;

    // Preserve the space the chat occupied so layout doesn't jump when restored
    const rect = chatContainer.getBoundingClientRect();
    chatPlaceholder.style.display = 'block';
    chatPlaceholder.style.height = rect.height + 'px';

    // Save original location and move chat to body
    originalParent = chatContainer.parentElement;
    originalNextSibling = chatContainer.nextSibling;
    document.body.appendChild(chatContainer);

    chatContainer.classList.add('fullscreen');
    document.body.classList.add('chat-fullscreen-open');

    // Lock scroll using position:fixed pattern (preserves scroll position)
    document.body.style.position = 'fixed';
    document.body.style.top = `-${savedScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.width = '100%';

    expandBtn.style.display = 'none';
    closeBtn.style.display = 'flex';

    setTimeout(() => {
      messagesEl.scrollTop = messagesEl.scrollHeight;
      inputEl.focus();
    }, 350);
  }

  function closeFullscreen() {
    if (!isFullscreen) return;
    isFullscreen = false;

    chatContainer.classList.remove('fullscreen');

    // Move chat back to its original position
    if (originalParent) {
      if (originalNextSibling) {
        originalParent.insertBefore(chatContainer, originalNextSibling);
      } else {
        originalParent.appendChild(chatContainer);
      }
      originalParent = null;
      originalNextSibling = null;
    }

    chatPlaceholder.style.display = 'none';
    document.body.classList.remove('chat-fullscreen-open');

    // Unlock scroll
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.style.width = '';

    // Restore scroll position to where the user was before opening the chat
    window.scrollTo(0, savedScrollY);

    expandBtn.style.display = 'flex';
    closeBtn.style.display = 'none';

    inputEl.blur();
  }

  interface ChatMsg { role: 'user' | 'assistant'; content: string; }
  const messages: ChatMsg[] = [];
  let isStreaming = false;
  let userMsgCount = 0;
  let cooldownActive = false;
  const MAX_MESSAGES = 20;

  // Generate or retrieve a session ID for this chat
  const SESSION_KEY = 'procesos360_chat_session';
  let sessionId = sessionStorage.getItem(SESSION_KEY);
  if (!sessionId) {
    sessionId = `s-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
    sessionStorage.setItem(SESSION_KEY, sessionId);
  }
  const WELCOME = '¡Hola! Soy el asistente digital de Procesos 360. Contame brevemente sobre tu empresa y el desafío que estás enfrentando hoy en términos de procesos o transformación digital, y te oriento sobre cómo podemos ayudarte.';

  const isMobile = window.matchMedia('(max-width: 640px)').matches;
  const bubbleMaxWidth = isMobile ? '88%' : '82%';
  const bubbleStyles: Record<string, string> = {
    assistant: `background:rgba(41,201,214,0.12);color:#0A1F4A;border:1px solid rgba(41,201,214,0.35);border-radius:4px 16px 16px 16px;max-width:${bubbleMaxWidth};padding:12px 16px;font-size:14.5px;line-height:1.55;word-break:break-word;font-family:var(--font-sans);`,
    user: `background:rgba(30,91,255,0.08);color:#0A1F4A;border:1px solid rgba(30,91,255,0.20);border-radius:16px 4px 16px 16px;max-width:${bubbleMaxWidth};padding:12px 16px;font-size:14.5px;line-height:1.55;word-break:break-word;font-family:var(--font-sans);`,
  };

  function addMessage(role: 'user' | 'assistant', content: string) {
    const optMatch = content.match(/\[OPCIONES:\s*(.+?)\]/);
    let cleanContent = content;
    let options: string[] = [];
    if (optMatch) {
      cleanContent = content.replace(optMatch[0], '').trim();
      options = optMatch[1].split('|').map(o => o.trim());
    }

    const wrapper = document.createElement('div');
    wrapper.style.cssText = `display:flex;${role === 'user' ? 'justify-content:flex-end;' : 'justify-content:flex-start;flex-direction:column;align-items:flex-start;'}`;

    const bubble = document.createElement('div');
    bubble.style.cssText = bubbleStyles[role];
    bubble.textContent = cleanContent;
    wrapper.appendChild(bubble);

    if (options.length > 0 && role === 'assistant') {
      const optContainer = document.createElement('div');
      optContainer.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;padding-left:4px;';
      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.style.cssText = 'background:transparent;color:var(--gold);border:1px solid rgba(229,66,181,0.4);border-radius:999px;padding:7px 15px;font-size:12.5px;font-weight:500;cursor:pointer;font-family:var(--font-sans);transition:all 0.3s;';
        btn.textContent = opt;
        btn.addEventListener('mouseover', () => { btn.style.background = 'var(--gold)'; btn.style.color = 'var(--night)'; });
        btn.addEventListener('mouseout', () => { btn.style.background = 'transparent'; btn.style.color = 'var(--gold)'; });
        btn.addEventListener('click', () => { optContainer.remove(); sendMessage(opt); });
        optContainer.appendChild(btn);
      });
      wrapper.appendChild(optContainer);
    }

    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return bubble;
  }

  function createStreamBubble(): HTMLDivElement {
    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'display:flex;justify-content:flex-start;flex-direction:column;align-items:flex-start;';
    const bubble = document.createElement('div');
    bubble.style.cssText = bubbleStyles.assistant;
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    return bubble;
  }

  function setLoading(loading: boolean) {
    isStreaming = loading;
    inputEl.disabled = loading;
    sendBtn.disabled = loading;
    sendIcon.style.display = loading ? 'none' : 'block';
    sendSpinner.style.display = loading ? 'block' : 'none';
    typingEl.style.display = loading ? 'flex' : 'none';
    if (loading) messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  async function sendMessage(text: string) {
    if (isStreaming || cooldownActive || !text.trim()) return;
    if (userMsgCount >= MAX_MESSAGES) { limitEl.style.display = 'flex'; return; }

    userMsgCount++;
    const userMsg = text.trim();
    addMessage('user', userMsg);
    messages.push({ role: 'user', content: userMsg });
    inputEl.value = '';
    inputEl.style.height = 'auto';
    charCount.style.display = 'none';
    setLoading(true);

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages, sessionId }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || 'server_error');
      }

      typingEl.style.display = 'none';
      const bubble = createStreamBubble();
      let fullText = '';

      const reader = res.body!.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';
        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const payload = line.slice(6).trim();
          if (payload === '[DONE]') continue;
          try {
            const { text: chunk } = JSON.parse(payload);
            if (chunk) {
              fullText += chunk;
              const optCheck = fullText.match(/\[OPCIONES:\s*(.+?)\]/);
              bubble.textContent = optCheck ? fullText.replace(optCheck[0], '').trim() : fullText;
              messagesEl.scrollTop = messagesEl.scrollHeight;
            }
          } catch {}
        }
      }

      messages.push({ role: 'assistant', content: fullText });

      const optMatch = fullText.match(/\[OPCIONES:\s*(.+?)\]/);
      if (optMatch) {
        bubble.textContent = fullText.replace(optMatch[0], '').trim();
        const options = optMatch[1].split('|').map((o: string) => o.trim());
        const optContainer = document.createElement('div');
        optContainer.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;padding-left:4px;';
        options.forEach((opt: string) => {
          const btn = document.createElement('button');
          btn.style.cssText = 'background:transparent;color:var(--gold);border:1px solid rgba(229,66,181,0.4);border-radius:999px;padding:7px 15px;font-size:12.5px;font-weight:500;cursor:pointer;font-family:var(--font-sans);transition:all 0.3s;';
          btn.textContent = opt;
          btn.addEventListener('mouseover', () => { btn.style.background = 'var(--gold)'; btn.style.color = 'var(--night)'; });
          btn.addEventListener('mouseout', () => { btn.style.background = 'transparent'; btn.style.color = 'var(--gold)'; });
          btn.addEventListener('click', () => { optContainer.remove(); sendMessage(opt); });
          optContainer.appendChild(btn);
        });
        bubble.parentElement!.appendChild(optContainer);
      }

    } catch (err: any) {
      typingEl.style.display = 'none';
      let errorMsg = 'Hubo un problema de conexión. Inténtalo de nuevo o déjanos tu consulta en el formulario.';
      if (err.message === 'rate_limit') errorMsg = 'Nuestro asistente está recibiendo muchas consultas. Intenta de nuevo en un minuto.';
      if (err.message === 'API key no configurada') errorMsg = 'Nuestro asistente está en mantenimiento. Puedes dejarnos tu consulta en el formulario.';
      addMessage('assistant', errorMsg);
      messages.push({ role: 'assistant', content: errorMsg });
    }

    setLoading(false);
    cooldownActive = true;
    setTimeout(() => { cooldownActive = false; }, 2000);
    if (userMsgCount >= MAX_MESSAGES) {
      limitEl.style.display = 'flex';
      inputEl.disabled = true;
    }
  }

  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage(inputEl.value);
    }
  });

  // Open fullscreen on any click/tap inside the chat container (when not yet fullscreen)
  chatContainer.addEventListener('click', (e) => {
    if (isFullscreen) return;
    openFullscreen();
  });
  // Also on focus (keyboard/tab navigation)
  inputEl.addEventListener('focus', openFullscreen);
  // Explicit expand button still works
  expandBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    openFullscreen();
  });
  // Close button (stop propagation so it doesn't bubble and re-open)
  closeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    closeFullscreen();
  });
  // ESC to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isFullscreen) closeFullscreen();
  });

  // Listen for global event from floating bubble (so any element on the page can open the chat)
  document.addEventListener('procesos360:open-chat', () => {
    if (!isFullscreen) {
      openFullscreen();
      // Scroll to ensure messages are visible
      setTimeout(() => {
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }, 100);
    }
  });

  sendBtn.addEventListener('click', () => sendMessage(inputEl.value));

  inputEl.addEventListener('input', () => {
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 100) + 'px';
    const remaining = 500 - inputEl.value.length;
    if (remaining < 50) {
      charCount.style.display = 'block';
      charCount.textContent = remaining.toString();
      charCount.style.color = remaining < 10 ? '#ef4444' : '#29C9D6';
    } else {
      charCount.style.display = 'none';
    }
  });

  addMessage('assistant', WELCOME);
</script>

<style>
  .chat-box {
    background: linear-gradient(180deg, #FFFFFF 0%, #F5F8FD 100%);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    border: 1px solid rgba(30, 91, 255, 0.15);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 20px 80px rgba(30, 91, 255, 0.12);
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .chat-box:not(.fullscreen):hover {
    border-color: rgba(30, 91, 255, 0.3);
    box-shadow: 0 24px 100px rgba(30, 91, 255, 0.18);
  }
  .chat-box.fullscreen {
    cursor: default;
  }
  @media (max-width: 640px) {
    .chat-box {
      border-radius: 16px;
    }
  }

  /* ===== FULLSCREEN MODE ===== */
  .chat-box.fullscreen {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    height: 100dvh !important;
    max-width: none !important;
    max-height: none !important;
    border-radius: 0 !important;
    border: none !important;
    z-index: 999 !important;
    background: linear-gradient(180deg, var(--night) 0%, var(--midnight) 100%) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    box-shadow: none !important;
    margin: 0 !important;
    animation: chat-fullscreen-in 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    display: flex !important;
    flex-direction: column !important;
  }

  @keyframes chat-fullscreen-in {
    from { opacity: 0; transform: scale(0.985); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Header in fullscreen: full width with bordered bottom */
  .chat-box.fullscreen .chat-header {
    padding: 14px 20px !important;
    background: rgba(255, 255, 255, 0.92) !important;
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(30, 91, 255, 0.1) !important;
    flex-shrink: 0;
    width: 100%;
  }
  .chat-box.fullscreen .chat-header > div:first-child,
  .chat-box.fullscreen .chat-header > .chat-header-right {
    /* Use flex on parent .chat-header which already has space-between */
  }
  /* Constrain header content width */
  .chat-box.fullscreen .chat-header {
    justify-content: center !important;
    position: relative;
  }
  .chat-box.fullscreen .chat-header > * {
    /* nothing */
  }
  /* Reset header to use a max-width via inner-style wrapper logic */
  .chat-box.fullscreen .chat-header {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    padding-left: max(20px, calc((100vw - 820px) / 2)) !important;
    padding-right: max(20px, calc((100vw - 820px) / 2)) !important;
  }

  /* Messages: flex-grow to fill the space, centered max-width */
  .chat-box.fullscreen .chat-messages {
    flex: 1 1 auto !important;
    min-height: 0 !important;
    height: auto !important;
    max-height: none !important;
    overflow-y: auto !important;
    padding: 24px max(20px, calc((100vw - 820px) / 2)) !important;
    width: 100%;
  }
  @media (min-width: 768px) {
    .chat-box.fullscreen .chat-messages {
      padding-top: 32px !important;
      padding-bottom: 32px !important;
    }
  }

  /* Typing indicator centered too */
  .chat-box.fullscreen .chat-typing {
    flex-shrink: 0;
    width: 100%;
    padding: 0 max(20px, calc((100vw - 820px) / 2)) 8px !important;
  }

  /* Input area sticky at bottom with backdrop */
  .chat-box.fullscreen .chat-input-area {
    flex-shrink: 0;
    padding: 14px max(20px, calc((100vw - 820px) / 2)) !important;
    padding-bottom: calc(14px + env(safe-area-inset-bottom)) !important;
    background: rgba(255, 255, 255, 0.92) !important;
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(30, 91, 255, 0.1) !important;
    width: 100%;
  }

  .chat-box.fullscreen .chat-header-caption {
    display: none !important;
  }

  /* body lock is handled via inline position:fixed in JS to preserve scroll */
  body.chat-fullscreen-open {
    overscroll-behavior: contain;
  }

  /* Expand / Close buttons */
  .chat-header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .chat-expand-btn,
  .chat-close-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(30, 91, 255, 0.08);
    border: 1px solid rgba(30, 91, 255, 0.15);
    color: var(--lavender);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.25s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .chat-expand-btn:hover,
  .chat-close-btn:hover {
    background: rgba(41, 201, 214, 0.25);
    border-color: rgba(41, 201, 214, 0.5);
    color: var(--cream);
  }
  .chat-close-btn {
    background: rgba(41, 201, 214, 0.2);
    border-color: rgba(41, 201, 214, 0.35);
    color: var(--cream);
  }

  .chat-header {
    background: rgba(30, 91, 255, 0.04);
    padding: 14px 16px;
