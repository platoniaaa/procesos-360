---
import Navbar from '../components/Navbar.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ChatBubble from '../components/ChatBubble.astro';
import ChatBot from '../components/ChatBot.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Procesos 360 | Consultoría en Gestión por Procesos, IA y Transformación Digital',
  description = 'Consultora chilena especializada en gestión por procesos, transformación digital con IA y modelamiento empresarial. Partners de SAP Signavio y SAP LeanIX. Diagnóstico de madurez gratuito.'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FFFFFF" />

    <!-- Theme: apply before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored
            ? stored
            : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>

    <link rel="icon" type="image/png" sizes="32x32" href="/img/isotipo.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/isotipo.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/isotipo.png" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="/img/logo-completo.png" />
    <meta property="og:locale" content="es_CL" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts: Clash Display (headlines) + Manrope (body) + JetBrains Mono (accents) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "name": "Procesos 360",
      "description": "Consultora chilena especializada en gestión por procesos, transformación digital con IA y modelamiento empresarial. Partners oficiales de SAP Signavio y SAP LeanIX.",
      "url": "https://procesos360.cl",
      "logo": "https://procesos360.cl/img/logo-completo.png",
      "address": { "@type": "PostalAddress", "addressLocality": "Santiago", "addressCountry": "CL" },
      "contactPoint": { "@type": "ContactPoint", "telephone": "+56964261751", "contactType": "sales", "availableLanguage": "Spanish" },
      "sameAs": []
    })} />
  </head>
  <body class="antialiased overflow-x-hidden">
    <Navbar />
    <main>
      <slot />
    </main>
    <ChatBubble />
    <ChatBot />
    <WhatsAppButton />

    <script>
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const fadeElements = document.querySelectorAll('.fade-up');

      // --- 1. Reveal al entrar en viewport ---
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target;
              el.classList.add('visible');
              revealObserver.unobserve(el);
              // Terminado el reveal, congelamos la transición CSS para que
              // el efecto de salida (ligado al scroll) responda al instante.
              window.setTimeout(() => el.classList.add('settled'), 1100);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      fadeElements.forEach(el => revealObserver.observe(el));

      // --- 2. Parallax + salida ligados al scroll ---
      // Cada bloque se desplaza a una velocidad distinta del scroll. Y al
      // salir por arriba acelera hacia arriba y se desvanece — así el
      // contenido se mueve igual al aparecer que al desaparecer.
      if (!prefersReduced) {
        const DEFAULT_SPEED = 0.045;
        const seen = new Set();
        const items = [];

        document.querySelectorAll('[data-parallax]').forEach((el) => {
          const speed = parseFloat(el.getAttribute('data-parallax')) || DEFAULT_SPEED;
          items.push({ el, speed, fade: el.classList.contains('fade-up'), op: -1 });
          seen.add(el);
        });
        fadeElements.forEach((el) => {
          if (!seen.has(el)) items.push({ el, speed: DEFAULT_SPEED, fade: true, op: -1 });
        });

        let ticking = false;

        const apply = () => {
          const vh = window.innerHeight;
          const viewportCenter = vh / 2;
          const exitZone = vh * 0.42;

          for (const item of items) {
            const { el, speed, fade } = item;
            const rect = el.getBoundingClientRect();
            // Fuera de rango: ahorra trabajo
            if (rect.bottom < -300 || rect.top > vh + 300) continue;

            // Parallax base — desplazamiento según distancia al centro
            const elementCenter = rect.top + rect.height / 2;
            const distance = elementCenter - viewportCenter;
            let shift = -distance * speed;
            if (shift > 90) shift = 90;
            else if (shift < -90) shift = -90;

            // Salida — el borde inferior entra en la zona superior
            let exit = 0;
            if (rect.bottom < exitZone) {
              exit = 1 - Math.max(0, rect.bottom) / exitZone;
              if (exit > 1) exit = 1;
            }
            const eased = exit * exit; // ease-in: acelera al salir

            el.style.setProperty('--parallax-y', (shift - eased * 80).toFixed(1) + 'px');

            // Fade de salida — sólo en bloques ya revelados
            if (fade && el.classList.contains('visible')) {
              const op = Math.round((1 - eased * 0.95) * 1000) / 1000;
              if (op !== item.op) {
                el.style.opacity = String(op);
                item.op = op;
              }
            }
          }
          ticking = false;
        };

        const onScroll = () => {
          if (!ticking) {
            window.requestAnimationFrame(apply);
            ticking = true;
          }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        apply();
      }
    </script>
  </body>
</html>
